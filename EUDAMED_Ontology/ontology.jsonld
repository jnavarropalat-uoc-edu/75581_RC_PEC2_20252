    "@id" : "http://www.semanticweb.org/joann/ontologies/2026/2/eudamed-ontology/Incident"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "Patient age"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#range" : [ {
    "@id" : "http://www.w3.org/2001/XMLSchema#string"
  } ]
}, {
  "@id" : "http://www.semanticweb.org/joann/ontologies/2026/2/eudamed-ontology/patient_sex",
  "@type" : [ "http://www.w3.org/2002/07/owl#DatatypeProperty" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "The sex of the patient involved in the incident."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#domain" : [ {
    "@id" : "http://www.semanticweb.org/joann/ontologies/2026/2/eudamed-ontology/Incident"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "Patient sex"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#range" : [ {
    "@id" : "http://www.semanticweb.org/joann/ontologies/2026/2/eudamed-ontology/personGender"
  } ]
}, {
  "@id" : "http://www.semanticweb.org/joann/ontologies/2026/2/eudamed-ontology/personGender",
  "@type" : [ "http://www.w3.org/2000/01/rdf-schema#Datatype" ]
