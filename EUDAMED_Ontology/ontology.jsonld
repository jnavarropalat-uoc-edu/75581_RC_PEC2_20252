  "@id" : "http://www.semanticweb.org/joann/ontologies/2026/2/eudamed-ontology/is_implantable",
  "@type" : [ "http://www.w3.org/2002/07/owl#DatatypeProperty" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "A boolean flag indicating whether the device is intended to be partially or wholly introduced into the human body."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#domain" : [ {
    "@id" : "https://schema.org/MedicalDevice"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "Is implantable"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#range" : [ {
    "@id" : "http://www.w3.org/2001/XMLSchema#boolean"
  } ]
}, {
  "@id" : "http://www.semanticweb.org/joann/ontologies/2026/2/eudamed-ontology/is_ivd",
  "@type" : [ "http://www.w3.org/2002/07/owl#DatatypeProperty" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "A boolean flag indicating whether the device is an In-Vitro Diagnostic (IVD) medical device."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#domain" : [ {
    "@id" : "https://schema.org/MedicalDevice"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
