  "@id" : "http://www.semanticweb.org/joann/ontologies/2026/2/eudamed-ontology/manufactures",
  "@type" : [ "http://www.w3.org/2002/07/owl#ObjectProperty" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "Relates an organization to the medical devices it produces. This is the inverse of eudamed:hasManufacturer."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "manufactures"
  } ]
