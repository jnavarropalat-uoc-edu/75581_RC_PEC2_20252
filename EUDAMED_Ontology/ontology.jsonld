}, {
  "@id" : "http://www.semanticweb.org/joann/ontologies/2026/2/eudamed-ontology/ImplantableDevice",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "A device intended to be placed into the human body, either partially or wholly, and remains after the procedure."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "Implantable medical device"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "https://schema.org/MedicalDevice"
  } ],
  "http://www.w3.org/2002/07/owl#sameAs" : [ {
    "@value" : "https://dbpedia.org/page/Implant_(medicine)"
  } ]
}, {
  "@id" : "http://www.semanticweb.org/joann/ontologies/2026/2/eudamed-ontology/InSituCorrection",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "A corrective action performed directly on the device at the point of use, such as a software update or hardware adjustment."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "In-Situ correction"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "http://www.semanticweb.org/joann/ontologies/2026/2/eudamed-ontology/CorrectiveAction"
  } ],
  "http://www.w3.org/2002/07/owl#equivalentClass" : [ {
    "@id" : "_:genid13"
  } ]
}, {
  "@id" : "http://www.semanticweb.org/joann/ontologies/2026/2/eudamed-ontology/InVitroDiagnostic",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "A device used to examine specimens derived from the human body to provide information for diagnostic or monitoring purposes (IVDR 2017/746)."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "In-Vitro diagnostic medical device"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "https://schema.org/MedicalDevice"
  } ]
}, {
  "@id" : "http://www.semanticweb.org/joann/ontologies/2026/2/eudamed-ontology/Incident",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class", "http://www.w3.org/2002/07/owl#NamedIndividual" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "An event that has resulted or could result in harm to a patient, user, or other person, associated with a medical device."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "Incident"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "_:genid17"
  } ],
  "http://www.w3.org/2002/07/owl#sameAs" : [ {
    "@value" : "http://dbpedia.org/resource/Incident_report"
  } ]
}, {
  "@id" : "http://www.semanticweb.org/joann/ontologies/2026/2/eudamed-ontology/InfectionRisk",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "Risk that the device causes or contributes to infection, particularly in implantable or reusable devices."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "Infection risk"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "http://www.semanticweb.org/joann/ontologies/2026/2/eudamed-ontology/MedicalRisk"
  } ],
  "http://www.w3.org/2002/07/owl#equivalentClass" : [ {
    "@id" : "_:genid18"
  } ]
}, {
  "@id" : "http://www.semanticweb.org/joann/ontologies/2026/2/eudamed-ontology/InjuryRisk",
