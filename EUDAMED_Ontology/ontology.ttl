@prefix : <http://www.semanticweb.org/joann/ontologies/2026/2/eudamed-ontology#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xml: <http://www.w3.org/XML/1998/namespace> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@base <http://www.semanticweb.org/joann/ontologies/2026/2/eudamed-ontology#> .

<http://www.semanticweb.org/joann/ontologies/2026/2/eudamed-ontology> rdf:type owl:Ontology ;
                                                                       owl:versionIRI <http://www.semanticweb.org/joann/ontologies/2026/2/eudamed-ontology/1.0.0> ;
                                                                       <http://purl.org/dc/elements/1.1/creator> "Joan Navarro Palatsi" ;
                                                                       <http://purl.org/dc/elements/1.1/description> "The ontology models the European catalog of high-risk medical devices and in vitro diagnostic devices in accordance with the MDR (EU 2017/745) and IVDR (EU 2017/746) regulations. It represents the concepts that underpin the domain: devices, risk classes, manufacturers, identified risks (using IMDRF nomenclature), reported incidents, and field safety corrective actions (FSCA). It draws on data from EUDAMED, and its design aims to facilitate semantic interoperability among manufacturers, regulatory authorities, hospitals, and patients."@en ;
                                                                       <http://purl.org/dc/elements/1.1/title> "EUDAMED-MDR/IVDR Ontology for Medical Devices and In-Vitro Diagnostics"@en ;
                                                                       owl:versionInfo "1.0"@en .

#################################################################
#    Annotation properties
#################################################################

###  http://purl.org/dc/elements/1.1/creator
<http://purl.org/dc/elements/1.1/creator> rdf:type owl:AnnotationProperty .


###  http://purl.org/dc/elements/1.1/description
<http://purl.org/dc/elements/1.1/description> rdf:type owl:AnnotationProperty .


###  http://purl.org/dc/elements/1.1/title
<http://purl.org/dc/elements/1.1/title> rdf:type owl:AnnotationProperty .


###  http://www.w3.org/1999/02/22-rdf-syntax-ns#type
rdf:type rdf:type owl:AnnotationProperty .


###  http://www.w3.org/2002/07/owl#sameAs
owl:sameAs rdf:type owl:AnnotationProperty .


###  http://www.w3.org/2004/02/skos/core#broader
<http://www.w3.org/2004/02/skos/core#broader> rdf:type owl:AnnotationProperty .


###  http://www.w3.org/2004/02/skos/core#closeMatch
<http://www.w3.org/2004/02/skos/core#closeMatch> rdf:type owl:AnnotationProperty .


###  http://www.w3.org/2004/02/skos/core#exactMatch
<http://www.w3.org/2004/02/skos/core#exactMatch> rdf:type owl:AnnotationProperty .


###  https://schema.org/dateCreated
<https://schema.org/dateCreated> rdf:type owl:AnnotationProperty .


###  https://schema.org/identifier
<https://schema.org/identifier> rdf:type owl:AnnotationProperty .


#################################################################
#    Datatypes
#################################################################

###  http://www.semanticweb.org/joann/ontologies/2026/2/eudamed-ontology/personGender
<http://www.semanticweb.org/joann/ontologies/2026/2/eudamed-ontology/personGender> rdf:type rdfs:Datatype .


###  http://www.w3.org/2001/XMLSchema#date
xsd:date rdf:type rdfs:Datatype .


#################################################################
#    Object Properties
#################################################################

###  http://www.semanticweb.org/joann/ontologies/2026/2/eudamed-ontology/addressesIncident
<http://www.semanticweb.org/joann/ontologies/2026/2/eudamed-ontology/addressesIncident> rdf:type owl:ObjectProperty ;
                                                                                        rdfs:domain <http://www.semanticweb.org/joann/ontologies/2026/2/eudamed-ontology/CorrectiveAction> ;
                                                                                        rdfs:range <http://www.semanticweb.org/joann/ontologies/2026/2/eudamed-ontology/Incident> ;
                                                                                        rdfs:comment "Links a corrective action to the incident that it addresses."@en ;
                                                                                        rdfs:label "addressesIncident"@en .


###  http://www.semanticweb.org/joann/ontologies/2026/2/eudamed-ontology/affectsDevice
<http://www.semanticweb.org/joann/ontologies/2026/2/eudamed-ontology/affectsDevice> rdf:type owl:ObjectProperty ;
                                                                                    owl:inverseOf <http://www.semanticweb.org/joann/ontologies/2026/2/eudamed-ontology/isAffectedBy> ;
                                                                                    rdf:type owl:FunctionalProperty ;
                                                                                    rdfs:domain <http://www.semanticweb.org/joann/ontologies/2026/2/eudamed-ontology/Incident> ;
                                                                                    rdfs:range <https://schema.org/MedicalDevice> ;
                                                                                    rdfs:comment "Indicates the medical device that is the subject of an incident report."@en ;
                                                                                    rdfs:label "affectsDevice"@en .


###  http://www.semanticweb.org/joann/ontologies/2026/2/eudamed-ontology/hasManufacturer
<http://www.semanticweb.org/joann/ontologies/2026/2/eudamed-ontology/hasManufacturer> rdf:type owl:ObjectProperty ;
                                                                                      owl:inverseOf <http://www.semanticweb.org/joann/ontologies/2026/2/eudamed-ontology/manufactures> ;
                                                                                      rdf:type owl:FunctionalProperty ;
                                                                                      rdfs:domain <https://schema.org/MedicalDevice> ;
                                                                                      rdfs:range <https://schema.org/Organization> ;
                                                                                      rdfs:comment "Associates a medical device with the organization that manufactured it."@en ;
                                                                                      rdfs:label "hasManufacturer"@en .


###  http://www.semanticweb.org/joann/ontologies/2026/2/eudamed-ontology/hasRisk
<http://www.semanticweb.org/joann/ontologies/2026/2/eudamed-ontology/hasRisk> rdf:type owl:ObjectProperty ,
                                                                                       owl:FunctionalProperty ;
                                                                              rdfs:domain <http://www.semanticweb.org/joann/ontologies/2026/2/eudamed-ontology/Incident> ;
                                                                              rdfs:range <http://www.semanticweb.org/joann/ontologies/2026/2/eudamed-ontology/MedicalRisk> ;
                                                                              rdfs:comment "Links an incident to the medical risk associated with it."@en ;
                                                                              rdfs:label "hasRisk"@en .


###  http://www.semanticweb.org/joann/ontologies/2026/2/eudamed-ontology/isAffectedBy
<http://www.semanticweb.org/joann/ontologies/2026/2/eudamed-ontology/isAffectedBy> rdf:type owl:ObjectProperty ;
                                                                                   rdfs:comment "Indicates that a device is impacted by a specific incident. This is the inverse of eudamed:affectsDevice."@en ;
                                                                                   rdfs:label "isAffectedBy"@en .


###  http://www.semanticweb.org/joann/ontologies/2026/2/eudamed-ontology/manufactures
<http://www.semanticweb.org/joann/ontologies/2026/2/eudamed-ontology/manufactures> rdf:type owl:ObjectProperty ;
                                                                                   rdfs:comment "Relates an organization to the medical devices it produces. This is the inverse of eudamed:hasManufacturer."@en ;
                                                                                   rdfs:label "manufactures"@en .


###  http://www.semanticweb.org/joann/ontologies/2026/2/eudamed-ontology/reportedBy
<http://www.semanticweb.org/joann/ontologies/2026/2/eudamed-ontology/reportedBy> rdf:type owl:ObjectProperty ;
                                                                                 owl:inverseOf <http://www.semanticweb.org/joann/ontologies/2026/2/eudamed-ontology/reports> ;
                                                                                 rdf:type owl:FunctionalProperty ;
                                                                                 rdfs:domain <http://www.semanticweb.org/joann/ontologies/2026/2/eudamed-ontology/Incident> ;
                                                                                 rdfs:range <https://schema.org/Organization> ;
                                                                                 rdfs:comment "Identifies the organization that submitted an incident report."@en ;
                                                                                 rdfs:label "reportedBy"@en .


###  http://www.semanticweb.org/joann/ontologies/2026/2/eudamed-ontology/reports
<http://www.semanticweb.org/joann/ontologies/2026/2/eudamed-ontology/reports> rdf:type owl:ObjectProperty ;
                                                                              rdfs:comment "Relates an organization to the incident reports it has submitted. This is the inverse of eudamed:reportedBy."@en ;
                                                                              rdfs:label "reports"@en .


###  https://schema.org/addressCountry
<https://schema.org/addressCountry> rdf:type owl:ObjectProperty .


#################################################################
#    Data properties
#################################################################

###  http://www.semanticweb.org/joann/ontologies/2026/2/eudamed-ontology/action_type
<http://www.semanticweb.org/joann/ontologies/2026/2/eudamed-ontology/action_type> rdf:type owl:DatatypeProperty ;
                                                                                  rdfs:domain <http://www.semanticweb.org/joann/ontologies/2026/2/eudamed-ontology/CorrectiveAction> ;
                                                                                  rdfs:range xsd:string ;
                                                                                  rdfs:comment "The type of corrective action taken, such as a safety alert, recall, or in-situ correction."@en ;
                                                                                  rdfs:label "Action type"@en .


###  http://www.semanticweb.org/joann/ontologies/2026/2/eudamed-ontology/affected_device_type
<http://www.semanticweb.org/joann/ontologies/2026/2/eudamed-ontology/affected_device_type> rdf:type owl:DatatypeProperty ;
                                                                                           rdfs:domain <http://www.semanticweb.org/joann/ontologies/2026/2/eudamed-ontology/MedicalRisk> ;
                                                                                           rdfs:range xsd:string ;
                                                                                           rdfs:comment "The type of device that is affected by a particular medical risk."@en ;
                                                                                           rdfs:label "Affected device type"@en .


###  http://www.semanticweb.org/joann/ontologies/2026/2/eudamed-ontology/authorization_number
<http://www.semanticweb.org/joann/ontologies/2026/2/eudamed-ontology/authorization_number> rdf:type owl:DatatypeProperty ;
                                                                                           rdfs:domain <https://schema.org/Organization> ;
                                                                                           rdfs:range xsd:string ;
                                                                                           rdfs:comment "The official authorization number or registration number assigned to an organization by a competent authority."@en ;
                                                                                           rdfs:label "Authorization number"@en .


###  http://www.semanticweb.org/joann/ontologies/2026/2/eudamed-ontology/competent_authority
<http://www.semanticweb.org/joann/ontologies/2026/2/eudamed-ontology/competent_authority> rdf:type owl:DatatypeProperty ;
                                                                                          rdfs:domain <https://schema.org/Organization> ;
                                                                                          rdfs:range xsd:string ;
                                                                                          rdfs:comment "The name of the national competent authority responsible for the organization."@en ;
                                                                                          rdfs:label "Competent authority"@en .


###  http://www.semanticweb.org/joann/ontologies/2026/2/eudamed-ontology/corrective_action_taken
<http://www.semanticweb.org/joann/ontologies/2026/2/eudamed-ontology/corrective_action_taken> rdf:type owl:DatatypeProperty ;
                                                                                              rdfs:domain <http://www.semanticweb.org/joann/ontologies/2026/2/eudamed-ontology/Incident> ;
                                                                                              rdfs:range xsd:boolean ;
                                                                                              rdfs:comment "A boolean flag indicating whether a corrective action has been taken in response to an incident."@en ;
                                                                                              rdfs:label "Corrective action taken"@en .


###  http://www.semanticweb.org/joann/ontologies/2026/2/eudamed-ontology/countries_affected
<http://www.semanticweb.org/joann/ontologies/2026/2/eudamed-ontology/countries_affected> rdf:type owl:DatatypeProperty ;
                                                                                         rdfs:domain <http://www.semanticweb.org/joann/ontologies/2026/2/eudamed-ontology/CorrectiveAction> ;
                                                                                         rdfs:range xsd:string ;
                                                                                         rdfs:comment "The countries where a corrective action is applicable."@en ;
                                                                                         rdfs:label "Countries affected"@en .


###  http://www.semanticweb.org/joann/ontologies/2026/2/eudamed-ontology/country_reported
<http://www.semanticweb.org/joann/ontologies/2026/2/eudamed-ontology/country_reported> rdf:type owl:DatatypeProperty ;
                                                                                       rdfs:domain <http://www.semanticweb.org/joann/ontologies/2026/2/eudamed-ontology/Incident> ;
                                                                                       rdfs:range xsd:string ;
                                                                                       rdfs:comment "The country from which an incident was reported, derived from the reporting organization's address."@en ;
                                                                                       rdfs:label "Country reported"@en .


###  http://www.semanticweb.org/joann/ontologies/2026/2/eudamed-ontology/detection_date
<http://www.semanticweb.org/joann/ontologies/2026/2/eudamed-ontology/detection_date> rdf:type owl:DatatypeProperty ;
                                                                                     rdfs:domain <http://www.semanticweb.org/joann/ontologies/2026/2/eudamed-ontology/Incident> ;
                                                                                     rdfs:range xsd:date ;
                                                                                     rdfs:comment "The date on which an incident was detected."@en ;
                                                                                     rdfs:label "Detection date"@en .


###  http://www.semanticweb.org/joann/ontologies/2026/2/eudamed-ontology/device_type
<http://www.semanticweb.org/joann/ontologies/2026/2/eudamed-ontology/device_type> rdf:type owl:DatatypeProperty ,
                                                                                           owl:FunctionalProperty ;
                                                                                  rdfs:domain <https://schema.org/MedicalDevice> ;
                                                                                  rdfs:range xsd:string ;
                                                                                  rdfs:comment "A general classification of the medical device, e.g., Implantable Active Device, In-Vitro Diagnostic."@en ;
                                                                                  rdfs:label "Device type"@en .


###  http://www.semanticweb.org/joann/ontologies/2026/2/eudamed-ontology/devices_affected
<http://www.semanticweb.org/joann/ontologies/2026/2/eudamed-ontology/devices_affected> rdf:type owl:DatatypeProperty ;
                                                                                       rdfs:domain <http://www.semanticweb.org/joann/ontologies/2026/2/eudamed-ontology/CorrectiveAction> ;
                                                                                       rdfs:range xsd:string ;
                                                                                       rdfs:comment "The number of devices impacted by a corrective action."@en ;
                                                                                       rdfs:label "Devices affected"@en .


###  http://www.semanticweb.org/joann/ontologies/2026/2/eudamed-ontology/eudamed_fsca_ref
<http://www.semanticweb.org/joann/ontologies/2026/2/eudamed-ontology/eudamed_fsca_ref> rdf:type owl:DatatypeProperty ;
                                                                                       rdfs:domain <http://www.semanticweb.org/joann/ontologies/2026/2/eudamed-ontology/CorrectiveAction> ;
                                                                                       rdfs:range xsd:string ;
                                                                                       rdfs:comment "The unique reference number assigned to a Field Safety Corrective Action (FSCA) in the EUDAMED database."@en ;
                                                                                       rdfs:label "Eudamed FSCA reference"@en .


###  http://www.semanticweb.org/joann/ontologies/2026/2/eudamed-ontology/eudamed_incident_ref
<http://www.semanticweb.org/joann/ontologies/2026/2/eudamed-ontology/eudamed_incident_ref> rdf:type owl:DatatypeProperty ;
                                                                                           rdfs:domain <http://www.semanticweb.org/joann/ontologies/2026/2/eudamed-ontology/Incident> ;
                                                                                           rdfs:range xsd:string ;
                                                                                           rdfs:comment "The unique reference number assigned to an incident report in the EUDAMED database."@en ;
                                                                                           rdfs:label "Eudamed incident reference"@en .


###  http://www.semanticweb.org/joann/ontologies/2026/2/eudamed-ontology/eudamed_srn
<http://www.semanticweb.org/joann/ontologies/2026/2/eudamed-ontology/eudamed_srn> rdf:type owl:DatatypeProperty ;
                                                                                  rdfs:domain <https://schema.org/Organization> ;
                                                                                  rdfs:range xsd:string ;
                                                                                  rdfs:comment "The unique Single Registration Number (SRN) assigned to an economic operator in the EUDAMED system."@en ;
                                                                                  rdfs:label "Eudamed SRN"@en .


###  http://www.semanticweb.org/joann/ontologies/2026/2/eudamed-ontology/event_date
<http://www.semanticweb.org/joann/ontologies/2026/2/eudamed-ontology/event_date> rdf:type owl:DatatypeProperty ;
                                                                                 rdfs:domain <http://www.semanticweb.org/joann/ontologies/2026/2/eudamed-ontology/Incident> ;
                                                                                 rdfs:range xsd:date ;
                                                                                 rdfs:comment "The date on which the incident occurred."@en ;
                                                                                 rdfs:label "Event date"@en .


###  http://www.semanticweb.org/joann/ontologies/2026/2/eudamed-ontology/imdrf_code
<http://www.semanticweb.org/joann/ontologies/2026/2/eudamed-ontology/imdrf_code> rdf:type owl:DatatypeProperty ;
                                                                                 rdfs:domain <http://www.semanticweb.org/joann/ontologies/2026/2/eudamed-ontology/MedicalRisk> ;
                                                                                 rdfs:range xsd:string ;
                                                                                 rdfs:comment "The code from the International Medical Device Regulators Forum (IMDRF) that classifies the type of medical risk."@en ;
                                                                                 rdfs:label "IMDRF Code"@en .


###  http://www.semanticweb.org/joann/ontologies/2026/2/eudamed-ontology/incident_type
<http://www.semanticweb.org/joann/ontologies/2026/2/eudamed-ontology/incident_type> rdf:type owl:DatatypeProperty ;
                                                                                    rdfs:domain <http://www.semanticweb.org/joann/ontologies/2026/2/eudamed-ontology/Incident> ;
                                                                                    rdfs:range xsd:string ;
                                                                                    rdfs:comment "The classification of the incident, e.g., serious incident or near-miss."@en ;
                                                                                    rdfs:label "Incident type"@en .


###  http://www.semanticweb.org/joann/ontologies/2026/2/eudamed-ontology/intended_purpose
<http://www.semanticweb.org/joann/ontologies/2026/2/eudamed-ontology/intended_purpose> rdf:type owl:DatatypeProperty ;
                                                                                       rdfs:domain <https://schema.org/MedicalDevice> ;
                                                                                       rdfs:range xsd:string ;
                                                                                       rdfs:comment "The intended use or clinical function of the medical device as defined by the manufacturer."@en ;
                                                                                       rdfs:label "Intended purpose"@en .


###  http://www.semanticweb.org/joann/ontologies/2026/2/eudamed-ontology/is_active
<http://www.semanticweb.org/joann/ontologies/2026/2/eudamed-ontology/is_active> rdf:type owl:DatatypeProperty ;
                                                                                rdfs:domain <https://schema.org/MedicalDevice> ;
                                                                                rdfs:range xsd:boolean ;
                                                                                rdfs:comment "A boolean flag indicating whether the device is an active medical device (dependent on a source of energy)."@en ;
                                                                                rdfs:label "Is active"@en .


###  http://www.semanticweb.org/joann/ontologies/2026/2/eudamed-ontology/is_implantable
<http://www.semanticweb.org/joann/ontologies/2026/2/eudamed-ontology/is_implantable> rdf:type owl:DatatypeProperty ;
                                                                                     rdfs:domain <https://schema.org/MedicalDevice> ;
                                                                                     rdfs:range xsd:boolean ;
                                                                                     rdfs:comment "A boolean flag indicating whether the device is intended to be partially or wholly introduced into the human body."@en ;
                                                                                     rdfs:label "Is implantable"@en .


###  http://www.semanticweb.org/joann/ontologies/2026/2/eudamed-ontology/is_ivd
<http://www.semanticweb.org/joann/ontologies/2026/2/eudamed-ontology/is_ivd> rdf:type owl:DatatypeProperty ;
                                                                             rdfs:domain <https://schema.org/MedicalDevice> ;
                                                                             rdfs:range xsd:boolean ;
                                                                             rdfs:comment "A boolean flag indicating whether the device is an In-Vitro Diagnostic (IVD) medical device."@en ;
                                                                             rdfs:label "Is IVD device"@en .


###  http://www.semanticweb.org/joann/ontologies/2026/2/eudamed-ontology/is_reusable
<http://www.semanticweb.org/joann/ontologies/2026/2/eudamed-ontology/is_reusable> rdf:type owl:DatatypeProperty ;
                                                                                  rdfs:domain <https://schema.org/MedicalDevice> ;
                                                                                  rdfs:range xsd:boolean ;
                                                                                  rdfs:comment "A boolean flag indicating whether the device can be reused after appropriate processing."@en ;
                                                                                  rdfs:label "Is reusable"@en .


###  http://www.semanticweb.org/joann/ontologies/2026/2/eudamed-ontology/outcome
<http://www.semanticweb.org/joann/ontologies/2026/2/eudamed-ontology/outcome> rdf:type owl:DatatypeProperty ;
                                                                              rdfs:domain <http://www.semanticweb.org/joann/ontologies/2026/2/eudamed-ontology/Incident> ;
                                                                              rdfs:range xsd:string ;
                                                                              rdfs:comment "A textual description of the consequences of the incident, such as patient harm or device malfunction."@en ;
                                                                              rdfs:label "Outcome"@en .


###  http://www.semanticweb.org/joann/ontologies/2026/2/eudamed-ontology/patient_age
<http://www.semanticweb.org/joann/ontologies/2026/2/eudamed-ontology/patient_age> rdf:type owl:DatatypeProperty ;
                                                                                  rdfs:domain <http://www.semanticweb.org/joann/ontologies/2026/2/eudamed-ontology/Incident> ;
                                                                                  rdfs:range xsd:string ;
                                                                                  rdfs:comment "The age of the patient involved in the incident."@en ;
                                                                                  rdfs:label "Patient age"@en .


###  http://www.semanticweb.org/joann/ontologies/2026/2/eudamed-ontology/patient_sex
<http://www.semanticweb.org/joann/ontologies/2026/2/eudamed-ontology/patient_sex> rdf:type owl:DatatypeProperty ;
                                                                                  rdfs:domain <http://www.semanticweb.org/joann/ontologies/2026/2/eudamed-ontology/Incident> ;
                                                                                  rdfs:range <http://www.semanticweb.org/joann/ontologies/2026/2/eudamed-ontology/personGender> ;
                                                                                  rdfs:comment "The sex of the patient involved in the incident."@en ;
                                                                                  rdfs:label "Patient sex"@en .


###  http://www.semanticweb.org/joann/ontologies/2026/2/eudamed-ontology/probability
<http://www.semanticweb.org/joann/ontologies/2026/2/eudamed-ontology/probability> rdf:type owl:DatatypeProperty ;
                                                                                  rdfs:domain <http://www.semanticweb.org/joann/ontologies/2026/2/eudamed-ontology/MedicalRisk> ;
                                                                                  rdfs:range xsd:string ;
                                                                                  rdfs:comment "The estimated likelihood of the risk occurring (e.g., Low, Medium, High)."@en ;
                                                                                  rdfs:label "Probability"@en .


###  http://www.semanticweb.org/joann/ontologies/2026/2/eudamed-ontology/regulatory_framework
<http://www.semanticweb.org/joann/ontologies/2026/2/eudamed-ontology/regulatory_framework> rdf:type owl:DatatypeProperty ;
                                                                                           rdfs:domain <https://schema.org/MedicalDevice> ;
                                                                                           rdfs:range xsd:string ;
                                                                                           rdfs:comment "The applicable regulation under which the device is placed on the market, such as MDR or IVDR."@en ;
                                                                                           rdfs:label "Regulatory framework"@en .


###  http://www.semanticweb.org/joann/ontologies/2026/2/eudamed-ontology/risk_category
<http://www.semanticweb.org/joann/ontologies/2026/2/eudamed-ontology/risk_category> rdf:type owl:DatatypeProperty ;
                                                                                    rdfs:domain <http://www.semanticweb.org/joann/ontologies/2026/2/eudamed-ontology/MedicalRisk> ;
                                                                                    rdfs:range xsd:string ;
                                                                                    rdfs:comment "The category of risk, such as Device Failure, Patient Harm, or Diagnostic Error."@en ;
                                                                                    rdfs:label "Risk category"@en .


###  http://www.semanticweb.org/joann/ontologies/2026/2/eudamed-ontology/risk_class
<http://www.semanticweb.org/joann/ontologies/2026/2/eudamed-ontology/risk_class> rdf:type owl:DatatypeProperty ;
                                                                                 rdfs:domain <https://schema.org/MedicalDevice> ;
                                                                                 rdfs:range xsd:string ;
                                                                                 rdfs:comment "The device risk class according to the regulatory framework (e.g., Class I, IIa, IIb, III for MDR; Class A, B, C, D for IVDR)."@en ;
                                                                                 rdfs:label "Risk class"@en .


###  http://www.semanticweb.org/joann/ontologies/2026/2/eudamed-ontology/risk_type
<http://www.semanticweb.org/joann/ontologies/2026/2/eudamed-ontology/risk_type> rdf:type owl:DatatypeProperty ;
                                                                                rdfs:domain <http://www.semanticweb.org/joann/ontologies/2026/2/eudamed-ontology/MedicalRisk> ;
                                                                                rdfs:range xsd:string ;
                                                                                rdfs:comment "A more specific classification of the risk, e.g., Malfunction Risk, Infection Risk, or Diagnostic Risk."@en ;
                                                                                rdfs:label "Risk type"@en .


###  http://www.semanticweb.org/joann/ontologies/2026/2/eudamed-ontology/scope
<http://www.semanticweb.org/joann/ontologies/2026/2/eudamed-ontology/scope> rdf:type owl:DatatypeProperty ;
                                                                            rdfs:domain <http://www.semanticweb.org/joann/ontologies/2026/2/eudamed-ontology/CorrectiveAction> ;
                                                                            rdfs:range xsd:string ;
                                                                            rdfs:comment "A textual description of the scope of a corrective action, detailing which devices or batches are included."@en ;
                                                                            rdfs:label "Scope"@en .


###  http://www.semanticweb.org/joann/ontologies/2026/2/eudamed-ontology/severity
<http://www.semanticweb.org/joann/ontologies/2026/2/eudamed-ontology/severity> rdf:type owl:DatatypeProperty ;
                                                                               rdfs:domain <http://www.semanticweb.org/joann/ontologies/2026/2/eudamed-ontology/MedicalRisk> ;
                                                                               rdfs:range xsd:string ;
                                                                               rdfs:comment "The level of severity of the medical risk (e.g., Critical, Serious, Moderate)."@en ;
                                                                               rdfs:label "Severity"@en .


###  http://www.semanticweb.org/joann/ontologies/2026/2/eudamed-ontology/status
<http://www.semanticweb.org/joann/ontologies/2026/2/eudamed-ontology/status> rdf:type owl:DatatypeProperty ;
                                                                             rdfs:domain <http://www.semanticweb.org/joann/ontologies/2026/2/eudamed-ontology/CorrectiveAction> ;
                                                                             rdfs:range xsd:string ;
                                                                             rdfs:comment "The current status of a corrective action (e.g., Open, Closed)."@en ;
                                                                             rdfs:label "Status"@en .


###  http://www.semanticweb.org/joann/ontologies/2026/2/eudamed-ontology/udi_di
<http://www.semanticweb.org/joann/ontologies/2026/2/eudamed-ontology/udi_di> rdf:type owl:DatatypeProperty ;
                                                                             rdfs:domain <https://schema.org/MedicalDevice> ;
                                                                             rdfs:range xsd:string ;
                                                                             rdfs:comment "The Unique Device Identifier - Device Identifier (UDI-DI) which serves as the primary identifier for a medical device model."@en ;
                                                                             rdfs:label "Unique Device Identifier - Device Identifier"@en .


#################################################################
#    Classes
#################################################################

###  http://www.semanticweb.org/joann/ontologies/2026/2/eudamed-ontology/ActiveDevice
<http://www.semanticweb.org/joann/ontologies/2026/2/eudamed-ontology/ActiveDevice> rdf:type owl:Class ;
                                                                                   rdfs:subClassOf <https://schema.org/MedicalDevice> ;
                                                                                   rdfs:comment "A device that depends on a source of energy (e.g., electrical, mechanical) to perform its function, excluding energy generated by the human body."@en ;
                                                                                   rdfs:label "Active medical device"@en .


###  http://www.semanticweb.org/joann/ontologies/2026/2/eudamed-ontology/ClassI
<http://www.semanticweb.org/joann/ontologies/2026/2/eudamed-ontology/ClassI> rdf:type owl:Class ;
                                                                             rdfs:subClassOf <https://schema.org/MedicalDevice> ;
                                                                             rdfs:comment "A low‑risk medical device under MDR 2017/745, typically subject to self‑declaration of conformity."@en ;
                                                                             rdfs:label "Class I medical device"@en .


###  http://www.semanticweb.org/joann/ontologies/2026/2/eudamed-ontology/ClassIII
<http://www.semanticweb.org/joann/ontologies/2026/2/eudamed-ontology/ClassIII> rdf:type owl:Class ;
                                                                               rdfs:subClassOf <https://schema.org/MedicalDevice> ;
                                                                               rdfs:comment "A high‑risk medical device under MDR 2017/745, requiring the highest level of scrutiny and clinical evaluation."@en ;
                                                                               rdfs:label "Class III medical device"@en .


###  http://www.semanticweb.org/joann/ontologies/2026/2/eudamed-ontology/ClassIIa
<http://www.semanticweb.org/joann/ontologies/2026/2/eudamed-ontology/ClassIIa> rdf:type owl:Class ;
                                                                               rdfs:subClassOf <https://schema.org/MedicalDevice> ;
                                                                               rdfs:comment "A medium‑risk medical device under MDR 2017/745, with moderate conformity assessment requirements."@en ;
                                                                               rdfs:label "Class IIa medical device"@en .


###  http://www.semanticweb.org/joann/ontologies/2026/2/eudamed-ontology/ClassIIb
<http://www.semanticweb.org/joann/ontologies/2026/2/eudamed-ontology/ClassIIb> rdf:type owl:Class ;
                                                                               rdfs:subClassOf <https://schema.org/MedicalDevice> ;
                                                                               rdfs:comment "A medium‑high risk medical device under MDR 2017/745, subject to strict conformity assessment procedures."@en ;
                                                                               rdfs:label "Class IIb medical device"@en .


###  http://www.semanticweb.org/joann/ontologies/2026/2/eudamed-ontology/ContaminationRisk
<http://www.semanticweb.org/joann/ontologies/2026/2/eudamed-ontology/ContaminationRisk> rdf:type owl:Class ;
                                                                                        owl:equivalentClass [ owl:intersectionOf ( <http://www.semanticweb.org/joann/ontologies/2026/2/eudamed-ontology/MedicalRisk>
                                                                                                                                   [ rdf:type owl:Restriction ;
                                                                                                                                     owl:onProperty <http://www.semanticweb.org/joann/ontologies/2026/2/eudamed-ontology/risk_type> ;
                                                                                                                                     owl:hasValue "ContaminationRisk"
                                                                                                                                   ]
                                                                                                                                 ) ;
                                                                                                              rdf:type owl:Class
                                                                                                            ] ;
                                                                                        rdfs:subClassOf <http://www.semanticweb.org/joann/ontologies/2026/2/eudamed-ontology/MedicalRisk> ;
                                                                                        rdfs:comment "Risk of microbial or chemical contamination of the device, potentially causing infection or adverse health effects."@en ;
                                                                                        rdfs:label "Contamination risk"@en .


###  http://www.semanticweb.org/joann/ontologies/2026/2/eudamed-ontology/CorrectiveAction
<http://www.semanticweb.org/joann/ontologies/2026/2/eudamed-ontology/CorrectiveAction> rdf:type owl:Class ;
                                                                                       rdfs:comment "A safety measure taken to address a device-related incident, including field safety corrective actions (FSCA) and recalls."@en ;
                                                                                       rdfs:label "Corrective action"@en ;
                                                                                       owl:sameAs "http://dbpedia.org/resource/Corrective_and_preventive_action" .


###  http://www.semanticweb.org/joann/ontologies/2026/2/eudamed-ontology/CybersecurityRisk
<http://www.semanticweb.org/joann/ontologies/2026/2/eudamed-ontology/CybersecurityRisk> rdf:type owl:Class ;
                                                                                        owl:equivalentClass [ owl:intersectionOf ( <http://www.semanticweb.org/joann/ontologies/2026/2/eudamed-ontology/MedicalRisk>
                                                                                                                                   [ rdf:type owl:Restriction ;
                                                                                                                                     owl:onProperty <http://www.semanticweb.org/joann/ontologies/2026/2/eudamed-ontology/risk_type> ;
                                                                                                                                     owl:hasValue "CybersecurityRisk"
                                                                                                                                   ]
                                                                                                                                 ) ;
                                                                                                              rdf:type owl:Class
                                                                                                            ] ;
                                                                                        rdfs:subClassOf <http://www.semanticweb.org/joann/ontologies/2026/2/eudamed-ontology/MedicalRisk> ;
                                                                                        rdfs:comment "Risk arising from vulnerabilities in the device's software or network connectivity that could lead to unauthorized access or malfunction."@en ;
                                                                                        rdfs:label "Cybersecurity risk"@en .


###  http://www.semanticweb.org/joann/ontologies/2026/2/eudamed-ontology/DiagnosticRisk
<http://www.semanticweb.org/joann/ontologies/2026/2/eudamed-ontology/DiagnosticRisk> rdf:type owl:Class ;
                                                                                     owl:equivalentClass [ owl:intersectionOf ( <http://www.semanticweb.org/joann/ontologies/2026/2/eudamed-ontology/MedicalRisk>
                                                                                                                                [ rdf:type owl:Restriction ;
                                                                                                                                  owl:onProperty <http://www.semanticweb.org/joann/ontologies/2026/2/eudamed-ontology/risk_type> ;
                                                                                                                                  owl:hasValue "DiagnosticRisk"
                                                                                                                                ]
                                                                                                                              ) ;
                                                                                                           rdf:type owl:Class
                                                                                                         ] ;
                                                                                     rdfs:subClassOf <http://www.semanticweb.org/joann/ontologies/2026/2/eudamed-ontology/MedicalRisk> ;
                                                                                     rdfs:comment "Risk associated with incorrect or delayed diagnosis due to device failure or misinterpretation of results."@en ;
                                                                                     rdfs:label "Diagnostic risk"@en .


###  http://www.semanticweb.org/joann/ontologies/2026/2/eudamed-ontology/ImplantableDevice
<http://www.semanticweb.org/joann/ontologies/2026/2/eudamed-ontology/ImplantableDevice> rdf:type owl:Class ;
                                                                                        rdfs:subClassOf <https://schema.org/MedicalDevice> ;
                                                                                        rdfs:comment "A device intended to be placed into the human body, either partially or wholly, and remains after the procedure."@en ;
                                                                                        rdfs:label "Implantable medical device"@en ;
                                                                                        owl:sameAs "https://dbpedia.org/page/Implant_(medicine)" .


###  http://www.semanticweb.org/joann/ontologies/2026/2/eudamed-ontology/InSituCorrection
<http://www.semanticweb.org/joann/ontologies/2026/2/eudamed-ontology/InSituCorrection> rdf:type owl:Class ;
                                                                                       owl:equivalentClass [ owl:intersectionOf ( <http://www.semanticweb.org/joann/ontologies/2026/2/eudamed-ontology/CorrectiveAction>
                                                                                                                                  [ rdf:type owl:Restriction ;
                                                                                                                                    owl:onProperty <http://www.semanticweb.org/joann/ontologies/2026/2/eudamed-ontology/action_type> ;
                                                                                                                                    owl:hasValue "InSituCorrection"
                                                                                                                                  ]
                                                                                                                                ) ;
                                                                                                             rdf:type owl:Class
                                                                                                           ] ;
                                                                                       rdfs:subClassOf <http://www.semanticweb.org/joann/ontologies/2026/2/eudamed-ontology/CorrectiveAction> ;
                                                                                       rdfs:comment "A corrective action performed directly on the device at the point of use, such as a software update or hardware adjustment."@en ;
                                                                                       rdfs:label "In-Situ correction"@en .


###  http://www.semanticweb.org/joann/ontologies/2026/2/eudamed-ontology/InVitroDiagnostic
<http://www.semanticweb.org/joann/ontologies/2026/2/eudamed-ontology/InVitroDiagnostic> rdf:type owl:Class ;
                                                                                        rdfs:subClassOf <https://schema.org/MedicalDevice> ;
                                                                                        rdfs:comment "A device used to examine specimens derived from the human body to provide information for diagnostic or monitoring purposes (IVDR 2017/746)."@en ;
                                                                                        rdfs:label "In-Vitro diagnostic medical device"@en .


###  http://www.semanticweb.org/joann/ontologies/2026/2/eudamed-ontology/Incident
<http://www.semanticweb.org/joann/ontologies/2026/2/eudamed-ontology/Incident> rdf:type owl:Class ;
                                                                               rdfs:subClassOf [ rdf:type owl:Restriction ;
                                                                                                 owl:onProperty <http://www.semanticweb.org/joann/ontologies/2026/2/eudamed-ontology/hasRisk> ;
                                                                                                 owl:minQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                                                                                                 owl:onClass <http://www.semanticweb.org/joann/ontologies/2026/2/eudamed-ontology/MedicalRisk>
                                                                                               ] .


###  http://www.semanticweb.org/joann/ontologies/2026/2/eudamed-ontology/InfectionRisk
<http://www.semanticweb.org/joann/ontologies/2026/2/eudamed-ontology/InfectionRisk> rdf:type owl:Class ;
                                                                                    owl:equivalentClass [ owl:intersectionOf ( <http://www.semanticweb.org/joann/ontologies/2026/2/eudamed-ontology/MedicalRisk>
                                                                                                                               [ rdf:type owl:Restriction ;
                                                                                                                                 owl:onProperty <http://www.semanticweb.org/joann/ontologies/2026/2/eudamed-ontology/risk_type> ;
                                                                                                                                 owl:hasValue "InfectionRisk"
                                                                                                                               ]
                                                                                                                             ) ;
                                                                                                          rdf:type owl:Class
                                                                                                        ] ;
                                                                                    rdfs:subClassOf <http://www.semanticweb.org/joann/ontologies/2026/2/eudamed-ontology/MedicalRisk> ;
                                                                                    rdfs:comment "Risk that the device causes or contributes to infection, particularly in implantable or reusable devices."@en ;
                                                                                    rdfs:label "Infection risk"@en .


###  http://www.semanticweb.org/joann/ontologies/2026/2/eudamed-ontology/InjuryRisk
<http://www.semanticweb.org/joann/ontologies/2026/2/eudamed-ontology/InjuryRisk> rdf:type owl:Class ;
                                                                                 owl:equivalentClass [ owl:intersectionOf ( <http://www.semanticweb.org/joann/ontologies/2026/2/eudamed-ontology/MedicalRisk>
                                                                                                                            [ rdf:type owl:Restriction ;
                                                                                                                              owl:onProperty <http://www.semanticweb.org/joann/ontologies/2026/2/eudamed-ontology/risk_type> ;
                                                                                                                              owl:hasValue "InjuryRisk"
                                                                                                                            ]
                                                                                                                          ) ;
                                                                                                       rdf:type owl:Class
                                                                                                     ] ;
                                                                                 rdfs:subClassOf <http://www.semanticweb.org/joann/ontologies/2026/2/eudamed-ontology/MedicalRisk> ;
                                                                                 rdfs:comment "Risk of physical harm or injury to the patient or user due to device failure or misuse."@en ;
                                                                                 rdfs:label "Injury risk"@en .


###  http://www.semanticweb.org/joann/ontologies/2026/2/eudamed-ontology/InterferenceRisk
<http://www.semanticweb.org/joann/ontologies/2026/2/eudamed-ontology/InterferenceRisk> rdf:type owl:Class ;
                                                                                       owl:equivalentClass [ owl:intersectionOf ( <http://www.semanticweb.org/joann/ontologies/2026/2/eudamed-ontology/MedicalRisk>
                                                                                                                                  [ rdf:type owl:Restriction ;
                                                                                                                                    owl:onProperty <http://www.semanticweb.org/joann/ontologies/2026/2/eudamed-ontology/risk_type> ;
                                                                                                                                    owl:hasValue "InterferenceRisk"
                                                                                                                                  ]
                                                                                                                                ) ;
                                                                                                             rdf:type owl:Class
                                                                                                           ] ;
                                                                                       rdfs:subClassOf <http://www.semanticweb.org/joann/ontologies/2026/2/eudamed-ontology/MedicalRisk> ;
                                                                                       rdfs:comment "Risk that the device causes or is affected by electromagnetic or other interference, compromising its performance."@en ;
                                                                                       rdfs:label "Interference risk"@en .


###  http://www.semanticweb.org/joann/ontologies/2026/2/eudamed-ontology/MalfunctionRisk
<http://www.semanticweb.org/joann/ontologies/2026/2/eudamed-ontology/MalfunctionRisk> rdf:type owl:Class ;
                                                                                      owl:equivalentClass [ owl:intersectionOf ( <http://www.semanticweb.org/joann/ontologies/2026/2/eudamed-ontology/MedicalRisk>
                                                                                                                                 [ rdf:type owl:Restriction ;
                                                                                                                                   owl:onProperty <http://www.semanticweb.org/joann/ontologies/2026/2/eudamed-ontology/risk_type> ;
                                                                                                                                   owl:hasValue "MalfunctionRisk"
                                                                                                                                 ]
                                                                                                                               ) ;
                                                                                                            rdf:type owl:Class
                                                                                                          ] ;
                                                                                      rdfs:subClassOf <http://www.semanticweb.org/joann/ontologies/2026/2/eudamed-ontology/MedicalRisk> ;
                                                                                      rdfs:comment "Risk that the device fails to perform as intended, potentially leading to delayed treatment or harm."@en ;
                                                                                      rdfs:label "Malfunction risk"@en .


###  http://www.semanticweb.org/joann/ontologies/2026/2/eudamed-ontology/MaterialRisk
<http://www.semanticweb.org/joann/ontologies/2026/2/eudamed-ontology/MaterialRisk> rdf:type owl:Class ;
                                                                                   owl:equivalentClass [ owl:intersectionOf ( <http://www.semanticweb.org/joann/ontologies/2026/2/eudamed-ontology/MedicalRisk>
                                                                                                                              [ rdf:type owl:Restriction ;
                                                                                                                                owl:onProperty <http://www.semanticweb.org/joann/ontologies/2026/2/eudamed-ontology/risk_type> ;
                                                                                                                                owl:hasValue "MaterialRisk"
                                                                                                                              ]
                                                                                                                            ) ;
                                                                                                         rdf:type owl:Class
                                                                                                       ] ;
                                                                                   rdfs:subClassOf <http://www.semanticweb.org/joann/ontologies/2026/2/eudamed-ontology/MedicalRisk> ;
                                                                                   rdfs:comment "Risk related to the materials used in the device, such as toxicity or biocompatibility issues."@en ;
                                                                                   rdfs:label "Material risk"@en .


###  http://www.semanticweb.org/joann/ontologies/2026/2/eudamed-ontology/MedicalRisk
<http://www.semanticweb.org/joann/ontologies/2026/2/eudamed-ontology/MedicalRisk> rdf:type owl:Class ;
                                                                                  rdfs:comment "A potential hazard associated with a medical device, classified according to the IMDRF nomenclature."@en ;
                                                                                  rdfs:label "Medical risk"@en .


###  http://www.semanticweb.org/joann/ontologies/2026/2/eudamed-ontology/NearMissIncident
<http://www.semanticweb.org/joann/ontologies/2026/2/eudamed-ontology/NearMissIncident> rdf:type owl:Class ;
                                                                                       rdfs:subClassOf <http://www.semanticweb.org/joann/ontologies/2026/2/eudamed-ontology/Incident> ;
                                                                                       rdfs:comment "An event that could have led to harm but did not, often due to timely intervention or chance."@en ;
                                                                                       rdfs:label "Near-Miss incident"@en .


###  http://www.semanticweb.org/joann/ontologies/2026/2/eudamed-ontology/NonActiveDevice
<http://www.semanticweb.org/joann/ontologies/2026/2/eudamed-ontology/NonActiveDevice> rdf:type owl:Class ;
                                                                                      rdfs:subClassOf <https://schema.org/MedicalDevice> ;
                                                                                      rdfs:comment "A device that does not rely on electrical or mechanical energy to function, such as bandages or surgical instruments."@en ;
                                                                                      rdfs:label "Non-Active medial device"@en .


###  http://www.semanticweb.org/joann/ontologies/2026/2/eudamed-ontology/RadiationRisk
<http://www.semanticweb.org/joann/ontologies/2026/2/eudamed-ontology/RadiationRisk> rdf:type owl:Class ;
                                                                                    owl:equivalentClass [ owl:intersectionOf ( <http://www.semanticweb.org/joann/ontologies/2026/2/eudamed-ontology/MedicalRisk>
                                                                                                                               [ rdf:type owl:Restriction ;
                                                                                                                                 owl:onProperty <http://www.semanticweb.org/joann/ontologies/2026/2/eudamed-ontology/risk_type> ;
                                                                                                                                 owl:hasValue "RadiationRisk"
                                                                                                                               ]
                                                                                                                             ) ;
                                                                                                          rdf:type owl:Class
                                                                                                        ] ;
                                                                                    rdfs:subClassOf <http://www.semanticweb.org/joann/ontologies/2026/2/eudamed-ontology/MedicalRisk> ;
                                                                                    rdfs:comment "Risk of excessive or unintended radiation exposure from the device, leading to tissue damage or other health effects."@en ;
                                                                                    rdfs:label "Radiation risk"@en .


###  http://www.semanticweb.org/joann/ontologies/2026/2/eudamed-ontology/Recall
<http://www.semanticweb.org/joann/ontologies/2026/2/eudamed-ontology/Recall> rdf:type owl:Class ;
                                                                             owl:equivalentClass [ owl:intersectionOf ( <http://www.semanticweb.org/joann/ontologies/2026/2/eudamed-ontology/CorrectiveAction>
                                                                                                                        [ rdf:type owl:Restriction ;
                                                                                                                          owl:onProperty <http://www.semanticweb.org/joann/ontologies/2026/2/eudamed-ontology/action_type> ;
                                                                                                                          owl:hasValue "Recall"
                                                                                                                        ]
                                                                                                                      ) ;
                                                                                                   rdf:type owl:Class
                                                                                                 ] ;
                                                                             rdfs:subClassOf <http://www.semanticweb.org/joann/ontologies/2026/2/eudamed-ontology/CorrectiveAction> ;
                                                                             rdfs:comment "Removal or correction of a device that is in violation of regulations or poses a safety risk, conducted by the manufacturer."@en ;
                                                                             rdfs:label "Recall"@en .


###  http://www.semanticweb.org/joann/ontologies/2026/2/eudamed-ontology/SafetyAlert
<http://www.semanticweb.org/joann/ontologies/2026/2/eudamed-ontology/SafetyAlert> rdf:type owl:Class ;
                                                                                  owl:equivalentClass [ owl:intersectionOf ( <http://www.semanticweb.org/joann/ontologies/2026/2/eudamed-ontology/CorrectiveAction>
                                                                                                                             [ rdf:type owl:Restriction ;
                                                                                                                               owl:onProperty <http://www.semanticweb.org/joann/ontologies/2026/2/eudamed-ontology/action_type> ;
                                                                                                                               owl:hasValue "SafetyAlert"
                                                                                                                             ]
                                                                                                                           ) ;
                                                                                                        rdf:type owl:Class
                                                                                                      ] ;
                                                                                  rdfs:subClassOf <http://www.semanticweb.org/joann/ontologies/2026/2/eudamed-ontology/CorrectiveAction> ;
                                                                                  rdfs:comment "An urgent notification issued to inform users about a serious safety issue and to recommend specific actions."@en ;
                                                                                  rdfs:label "Safety alert"@en .


###  http://www.semanticweb.org/joann/ontologies/2026/2/eudamed-ontology/SeriousIncident
<http://www.semanticweb.org/joann/ontologies/2026/2/eudamed-ontology/SeriousIncident> rdf:type owl:Class ;
                                                                                      rdfs:subClassOf <http://www.semanticweb.org/joann/ontologies/2026/2/eudamed-ontology/Incident> ;
                                                                                      rdfs:comment "An incident that resulted in death, serious deterioration in health, or a life‑threatening situation."@en ;
                                                                                      rdfs:label "Serious incident"@en .


###  http://www.semanticweb.org/joann/ontologies/2026/2/eudamed-ontology/SoftwareRisk
<http://www.semanticweb.org/joann/ontologies/2026/2/eudamed-ontology/SoftwareRisk> rdf:type owl:Class ;
                                                                                   owl:equivalentClass [ owl:intersectionOf ( <http://www.semanticweb.org/joann/ontologies/2026/2/eudamed-ontology/MedicalRisk>
                                                                                                                              [ rdf:type owl:Restriction ;
                                                                                                                                owl:onProperty <http://www.semanticweb.org/joann/ontologies/2026/2/eudamed-ontology/risk_type> ;
                                                                                                                                owl:hasValue "SoftwareRisk"
                                                                                                                              ]
                                                                                                                            ) ;
                                                                                                         rdf:type owl:Class
                                                                                                       ] ;
                                                                                   rdfs:subClassOf <http://www.semanticweb.org/joann/ontologies/2026/2/eudamed-ontology/MedicalRisk> ;
                                                                                   rdfs:comment "Risk associated with software bugs, inadequate functionality, or cybersecurity flaws in the device's software."@en ;
                                                                                   rdfs:label "Software risk"@en .


###  http://www.semanticweb.org/joann/ontologies/2026/2/eudamed-ontology/UserNotice
<http://www.semanticweb.org/joann/ontologies/2026/2/eudamed-ontology/UserNotice> rdf:type owl:Class ;
                                                                                 owl:equivalentClass [ owl:intersectionOf ( <http://www.semanticweb.org/joann/ontologies/2026/2/eudamed-ontology/CorrectiveAction>
                                                                                                                            [ rdf:type owl:Restriction ;
                                                                                                                              owl:onProperty <http://www.semanticweb.org/joann/ontologies/2026/2/eudamed-ontology/action_type> ;
                                                                                                                              owl:hasValue "UserNotice"
                                                                                                                            ]
                                                                                                                          ) ;
                                                                                                       rdf:type owl:Class
                                                                                                     ] ;
                                                                                 rdfs:subClassOf <http://www.semanticweb.org/joann/ontologies/2026/2/eudamed-ontology/CorrectiveAction> ;
                                                                                 rdfs:comment "A communication to users (e.g., healthcare providers, patients) providing instructions or warnings regarding device use."@en ;
                                                                                 rdfs:label "User notice"@en .


###  https://schema.org/MedicalDevice
<https://schema.org/MedicalDevice> rdf:type owl:Class .


###  https://schema.org/Organization
<https://schema.org/Organization> rdf:type owl:Class .


#################################################################
#    Individuals
#################################################################

###  http://www.semanticweb.org/joann/ontologies/2026/2/eudamed-ontology/DEV-001
<http://www.semanticweb.org/joann/ontologies/2026/2/eudamed-ontology/DEV-001> rdf:type owl:NamedIndividual ,
                                                                                       <https://schema.org/MedicalDevice> ;
