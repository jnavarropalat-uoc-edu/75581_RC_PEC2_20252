}, {
  "@id" : "http://www.semanticweb.org/joann/ontologies/2026/2/eudamed-ontology",
  "@type" : [ "http://www.w3.org/2002/07/owl#Ontology" ],
  "http://purl.org/dc/elements/1.1/creator" : [ {
    "@value" : "Joan Navarro Palatsi"
  } ],
  "http://purl.org/dc/elements/1.1/description" : [ {
    "@language" : "en",
    "@value" : "The ontology models the European catalog of high-risk medical devices and in vitro diagnostic devices in accordance with the MDR (EU 2017/745) and IVDR (EU 2017/746) regulations. It represents the concepts that underpin the domain: devices, risk classes, manufacturers, identified risks (using IMDRF nomenclature), reported incidents, and field safety corrective actions (FSCA). It draws on data from EUDAMED, and its design aims to facilitate semantic interoperability among manufacturers, regulatory authorities, hospitals, and patients."
  } ],
  "http://purl.org/dc/elements/1.1/title" : [ {
    "@language" : "en",
    "@value" : "EUDAMED-MDR/IVDR Ontology for Medical Devices and In-Vitro Diagnostics"
  } ],
  "http://purl.org/dc/terms/bibliographicCitation" : [ {
    "@language" : "en",
    "@value" : "Navarro Palatsi, J. (2026). EUDAMED-MDR/IVDR Ontology."
  } ],
  "http://purl.org/dc/terms/contributor" : [ {
    "@value" : "Joan Navarro Palatsi"
  } ],
  "http://purl.org/dc/terms/created" : [ {
    "@value" : "2026-03-28"
  } ],
