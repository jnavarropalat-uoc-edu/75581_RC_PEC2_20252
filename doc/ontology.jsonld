}, {
  "@id" : "http://www.semanticweb.org/joann/ontologies/2026/2/eudamed-ontology/ActiveDevice",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "A device that depends on a source of energy (e.g., electrical, mechanical) to perform its function, excluding energy generated by the human body."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "Active medical device"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "https://schema.org/MedicalDevice"
  } ]
}, {
  "@id" : "http://www.semanticweb.org/joann/ontologies/2026/2/eudamed-ontology/ClassI",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "A low‑risk medical device under MDR 2017/745, typically subject to self‑declaration of conformity."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "Class I medical device"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "https://schema.org/MedicalDevice"
  } ]
}, {
  "@id" : "http://www.semanticweb.org/joann/ontologies/2026/2/eudamed-ontology/ClassIII",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "A high‑risk medical device under MDR 2017/745, requiring the highest level of scrutiny and clinical evaluation."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "Class III medical device"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "https://schema.org/MedicalDevice"
  } ]
}, {
  "@id" : "http://www.semanticweb.org/joann/ontologies/2026/2/eudamed-ontology/ClassIIa",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "A medium‑risk medical device under MDR 2017/745, with moderate conformity assessment requirements."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "Class IIa medical device"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "https://schema.org/MedicalDevice"
  } ]
}, {
  "@id" : "http://www.semanticweb.org/joann/ontologies/2026/2/eudamed-ontology/ClassIIb",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "A medium‑high risk medical device under MDR 2017/745, subject to strict conformity assessment procedures."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "Class IIb medical device"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "https://schema.org/MedicalDevice"
  } ]
}, {
  "@id" : "http://www.semanticweb.org/joann/ontologies/2026/2/eudamed-ontology/ContaminationRisk",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "Risk of microbial or chemical contamination of the device, potentially causing infection or adverse health effects."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "Contamination risk"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "http://www.semanticweb.org/joann/ontologies/2026/2/eudamed-ontology/MedicalRisk"
  } ],
  "http://www.w3.org/2002/07/owl#equivalentClass" : [ {
    "@id" : "_:genid5"
  } ]
}, {
  "@id" : "http://www.semanticweb.org/joann/ontologies/2026/2/eudamed-ontology/CorrectiveAction",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "A safety measure taken to address a device-related incident, including field safety corrective actions (FSCA) and recalls."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "Corrective action"
  } ],
  "http://www.w3.org/2002/07/owl#sameAs" : [ {
    "@value" : "http://dbpedia.org/resource/Corrective_and_preventive_action"
  } ]
}, {
  "@id" : "http://www.semanticweb.org/joann/ontologies/2026/2/eudamed-ontology/CybersecurityRisk",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "Risk arising from vulnerabilities in the device's software or network connectivity that could lead to unauthorized access or malfunction."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "Cybersecurity risk"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "http://www.semanticweb.org/joann/ontologies/2026/2/eudamed-ontology/MedicalRisk"
  } ],
  "http://www.w3.org/2002/07/owl#equivalentClass" : [ {
    "@id" : "_:genid9"
  } ]
