                        <owl:hasValue>RadiationRisk</owl:hasValue>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </owl:equivalentClass>
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/joann/ontologies/2026/2/eudamed-ontology/MedicalRisk"/>
        <rdfs:comment xml:lang="en">Risk of excessive or unintended radiation exposure from the device, leading to tissue damage or other health effects.</rdfs:comment>
        <rdfs:label xml:lang="en">Radiation risk</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/joann/ontologies/2026/2/eudamed-ontology/Recall -->

    <owl:Class rdf:about="http://www.semanticweb.org/joann/ontologies/2026/2/eudamed-ontology/Recall">
        <owl:equivalentClass>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="http://www.semanticweb.org/joann/ontologies/2026/2/eudamed-ontology/CorrectiveAction"/>
                    <owl:Restriction>
