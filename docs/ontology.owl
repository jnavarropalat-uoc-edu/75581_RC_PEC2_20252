<?xml version="1.0"?>
<rdf:RDF xmlns="http://www.semanticweb.org/joann/ontologies/2026/2/eudamed-ontology#"
     xml:base="http://www.semanticweb.org/joann/ontologies/2026/2/eudamed-ontology"
     xmlns:dc="http://purl.org/dc/elements/1.1/"
     xmlns:owl="http://www.w3.org/2002/07/owl#"
     xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
     xmlns:xml="http://www.w3.org/XML/1998/namespace"
     xmlns:xsd="http://www.w3.org/2001/XMLSchema#"
     xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#"
     xmlns:skos="http://www.w3.org/2004/02/skos/core#"
     xmlns:swrl="http://www.w3.org/2003/11/swrl#"
     xmlns:swrlb="http://www.w3.org/2003/11/swrlb#"
     xmlns:schema="https://schema.org/"
     xmlns:eudamed-ontology="http://www.semanticweb.org/joann/ontologies/2026/2/eudamed-ontology/">
    <owl:Ontology rdf:about="http://www.semanticweb.org/joann/ontologies/2026/2/eudamed-ontology">
        <owl:versionIRI rdf:resource="http://www.semanticweb.org/joann/ontologies/2026/2/eudamed-ontology/1.0.0"/>
        <dc:creator>Joan Navarro Palatsi</dc:creator>
        <dc:description xml:lang="en">The ontology models the European catalog of high-risk medical devices and in vitro diagnostic devices in accordance with the MDR (EU 2017/745) and IVDR (EU 2017/746) regulations. It represents the concepts that underpin the domain: devices, risk classes, manufacturers, identified risks (using IMDRF nomenclature), reported incidents, and field safety corrective actions (FSCA). It draws on data from EUDAMED, and its design aims to facilitate semantic interoperability among manufacturers, regulatory authorities, hospitals, and patients.</dc:description>
        <dc:title xml:lang="en">EUDAMED-MDR/IVDR Ontology for Medical Devices and In-Vitro Diagnostics</dc:title>
        <owl:versionInfo xml:lang="en">1.0</owl:versionInfo>
    </owl:Ontology>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Annotation properties
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->


    


    <!-- http://purl.org/dc/elements/1.1/creator -->


    <owl:AnnotationProperty rdf:about="http://purl.org/dc/elements/1.1/creator"/>
    


    <!-- http://purl.org/dc/elements/1.1/description -->


    <owl:AnnotationProperty rdf:about="http://purl.org/dc/elements/1.1/description"/>
    


    <!-- http://purl.org/dc/elements/1.1/title -->


    <owl:AnnotationProperty rdf:about="http://purl.org/dc/elements/1.1/title"/>
    


    <!-- http://www.w3.org/1999/02/22-rdf-syntax-ns#type -->


    <owl:AnnotationProperty rdf:about="http://www.w3.org/1999/02/22-rdf-syntax-ns#type"/>
    


    <!-- http://www.w3.org/2002/07/owl#sameAs -->


    <owl:AnnotationProperty rdf:about="http://www.w3.org/2002/07/owl#sameAs"/>
    


    <!-- http://www.w3.org/2004/02/skos/core#broader -->


    <owl:AnnotationProperty rdf:about="http://www.w3.org/2004/02/skos/core#broader"/>
    


    <!-- http://www.w3.org/2004/02/skos/core#closeMatch -->


    <owl:AnnotationProperty rdf:about="http://www.w3.org/2004/02/skos/core#closeMatch"/>
    


    <!-- http://www.w3.org/2004/02/skos/core#exactMatch -->


    <owl:AnnotationProperty rdf:about="http://www.w3.org/2004/02/skos/core#exactMatch"/>
    


    <!-- https://schema.org/dateCreated -->


    <owl:AnnotationProperty rdf:about="https://schema.org/dateCreated"/>
    


    <!-- https://schema.org/identifier -->


    <owl:AnnotationProperty rdf:about="https://schema.org/identifier"/>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Datatypes
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->


    


    <!-- http://www.semanticweb.org/joann/ontologies/2026/2/eudamed-ontology/personGender -->


    <rdfs:Datatype rdf:about="http://www.semanticweb.org/joann/ontologies/2026/2/eudamed-ontology/personGender"/>
    


    <!-- http://www.w3.org/2001/XMLSchema#date -->


    <rdfs:Datatype rdf:about="http://www.w3.org/2001/XMLSchema#date"/>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Object Properties
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->


    


    <!-- http://www.semanticweb.org/joann/ontologies/2026/2/eudamed-ontology/addressesIncident -->


    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/joann/ontologies/2026/2/eudamed-ontology/addressesIncident">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/joann/ontologies/2026/2/eudamed-ontology/CorrectiveAction"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/joann/ontologies/2026/2/eudamed-ontology/Incident"/>
        <rdfs:comment xml:lang="en">Links a corrective action to the incident that it addresses.</rdfs:comment>
        <rdfs:label xml:lang="en">addressesIncident</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/joann/ontologies/2026/2/eudamed-ontology/affectsDevice -->


    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/joann/ontologies/2026/2/eudamed-ontology/affectsDevice">
        <owl:inverseOf rdf:resource="http://www.semanticweb.org/joann/ontologies/2026/2/eudamed-ontology/isAffectedBy"/>
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="http://www.semanticweb.org/joann/ontologies/2026/2/eudamed-ontology/Incident"/>
        <rdfs:range rdf:resource="https://schema.org/MedicalDevice"/>
        <rdfs:comment xml:lang="en">Indicates the medical device that is the subject of an incident report.</rdfs:comment>
        <rdfs:label xml:lang="en">affectsDevice</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/joann/ontologies/2026/2/eudamed-ontology/hasManufacturer -->


    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/joann/ontologies/2026/2/eudamed-ontology/hasManufacturer">
        <owl:inverseOf rdf:resource="http://www.semanticweb.org/joann/ontologies/2026/2/eudamed-ontology/manufactures"/>
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="https://schema.org/MedicalDevice"/>
        <rdfs:range rdf:resource="https://schema.org/Organization"/>
        <rdfs:comment xml:lang="en">Associates a medical device with the organization that manufactured it.</rdfs:comment>
        <rdfs:label xml:lang="en">hasManufacturer</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/joann/ontologies/2026/2/eudamed-ontology/hasRisk -->


    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/joann/ontologies/2026/2/eudamed-ontology/hasRisk">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="http://www.semanticweb.org/joann/ontologies/2026/2/eudamed-ontology/Incident"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/joann/ontologies/2026/2/eudamed-ontology/MedicalRisk"/>
        <rdfs:comment xml:lang="en">Links an incident to the medical risk associated with it.</rdfs:comment>
        <rdfs:label xml:lang="en">hasRisk</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/joann/ontologies/2026/2/eudamed-ontology/isAffectedBy -->


    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/joann/ontologies/2026/2/eudamed-ontology/isAffectedBy">
        <rdfs:comment xml:lang="en">Indicates that a device is impacted by a specific incident. This is the inverse of eudamed:affectsDevice.</rdfs:comment>
        <rdfs:label xml:lang="en">isAffectedBy</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/joann/ontologies/2026/2/eudamed-ontology/manufactures -->


    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/joann/ontologies/2026/2/eudamed-ontology/manufactures">
        <rdfs:comment xml:lang="en">Relates an organization to the medical devices it produces. This is the inverse of eudamed:hasManufacturer.</rdfs:comment>
        <rdfs:label xml:lang="en">manufactures</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/joann/ontologies/2026/2/eudamed-ontology/reportedBy -->


    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/joann/ontologies/2026/2/eudamed-ontology/reportedBy">
        <owl:inverseOf rdf:resource="http://www.semanticweb.org/joann/ontologies/2026/2/eudamed-ontology/reports"/>
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="http://www.semanticweb.org/joann/ontologies/2026/2/eudamed-ontology/Incident"/>
        <rdfs:range rdf:resource="https://schema.org/Organization"/>
        <rdfs:comment xml:lang="en">Identifies the organization that submitted an incident report.</rdfs:comment>
        <rdfs:label xml:lang="en">reportedBy</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/joann/ontologies/2026/2/eudamed-ontology/reports -->


    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/joann/ontologies/2026/2/eudamed-ontology/reports">
        <rdfs:comment xml:lang="en">Relates an organization to the incident reports it has submitted. This is the inverse of eudamed:reportedBy.</rdfs:comment>
        <rdfs:label xml:lang="en">reports</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://schema.org/addressCountry -->


    <owl:ObjectProperty rdf:about="https://schema.org/addressCountry"/>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Data properties
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->


    


    <!-- http://www.semanticweb.org/joann/ontologies/2026/2/eudamed-ontology/action_type -->


    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/joann/ontologies/2026/2/eudamed-ontology/action_type">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/joann/ontologies/2026/2/eudamed-ontology/CorrectiveAction"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment xml:lang="en">The type of corrective action taken, such as a safety alert, recall, or in-situ correction.</rdfs:comment>
        <rdfs:label xml:lang="en">Action type</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://www.semanticweb.org/joann/ontologies/2026/2/eudamed-ontology/affected_device_type -->


    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/joann/ontologies/2026/2/eudamed-ontology/affected_device_type">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/joann/ontologies/2026/2/eudamed-ontology/MedicalRisk"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment xml:lang="en">The type of device that is affected by a particular medical risk.</rdfs:comment>
        <rdfs:label xml:lang="en">Affected device type</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://www.semanticweb.org/joann/ontologies/2026/2/eudamed-ontology/authorization_number -->


    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/joann/ontologies/2026/2/eudamed-ontology/authorization_number">
        <rdfs:domain rdf:resource="https://schema.org/Organization"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment xml:lang="en">The official authorization number or registration number assigned to an organization by a competent authority.</rdfs:comment>
        <rdfs:label xml:lang="en">Authorization number</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://www.semanticweb.org/joann/ontologies/2026/2/eudamed-ontology/competent_authority -->


    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/joann/ontologies/2026/2/eudamed-ontology/competent_authority">
        <rdfs:domain rdf:resource="https://schema.org/Organization"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment xml:lang="en">The name of the national competent authority responsible for the organization.</rdfs:comment>
        <rdfs:label xml:lang="en">Competent authority</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://www.semanticweb.org/joann/ontologies/2026/2/eudamed-ontology/corrective_action_taken -->


    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/joann/ontologies/2026/2/eudamed-ontology/corrective_action_taken">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/joann/ontologies/2026/2/eudamed-ontology/Incident"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#boolean"/>
        <rdfs:comment xml:lang="en">A boolean flag indicating whether a corrective action has been taken in response to an incident.</rdfs:comment>
        <rdfs:label xml:lang="en">Corrective action taken</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://www.semanticweb.org/joann/ontologies/2026/2/eudamed-ontology/countries_affected -->


    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/joann/ontologies/2026/2/eudamed-ontology/countries_affected">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/joann/ontologies/2026/2/eudamed-ontology/CorrectiveAction"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment xml:lang="en">The countries where a corrective action is applicable.</rdfs:comment>
        <rdfs:label xml:lang="en">Countries affected</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://www.semanticweb.org/joann/ontologies/2026/2/eudamed-ontology/country_reported -->


    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/joann/ontologies/2026/2/eudamed-ontology/country_reported">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/joann/ontologies/2026/2/eudamed-ontology/Incident"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment xml:lang="en">The country from which an incident was reported, derived from the reporting organization&apos;s address.</rdfs:comment>
        <rdfs:label xml:lang="en">Country reported</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://www.semanticweb.org/joann/ontologies/2026/2/eudamed-ontology/detection_date -->


    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/joann/ontologies/2026/2/eudamed-ontology/detection_date">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/joann/ontologies/2026/2/eudamed-ontology/Incident"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#date"/>
        <rdfs:comment xml:lang="en">The date on which an incident was detected.</rdfs:comment>
        <rdfs:label xml:lang="en">Detection date</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://www.semanticweb.org/joann/ontologies/2026/2/eudamed-ontology/device_type -->


    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/joann/ontologies/2026/2/eudamed-ontology/device_type">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="https://schema.org/MedicalDevice"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment xml:lang="en">A general classification of the medical device, e.g., Implantable Active Device, In-Vitro Diagnostic.</rdfs:comment>
        <rdfs:label xml:lang="en">Device type</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://www.semanticweb.org/joann/ontologies/2026/2/eudamed-ontology/devices_affected -->


    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/joann/ontologies/2026/2/eudamed-ontology/devices_affected">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/joann/ontologies/2026/2/eudamed-ontology/CorrectiveAction"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment xml:lang="en">The number of devices impacted by a corrective action.</rdfs:comment>
        <rdfs:label xml:lang="en">Devices affected</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://www.semanticweb.org/joann/ontologies/2026/2/eudamed-ontology/eudamed_fsca_ref -->


    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/joann/ontologies/2026/2/eudamed-ontology/eudamed_fsca_ref">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/joann/ontologies/2026/2/eudamed-ontology/CorrectiveAction"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment xml:lang="en">The unique reference number assigned to a Field Safety Corrective Action (FSCA) in the EUDAMED database.</rdfs:comment>
        <rdfs:label xml:lang="en">Eudamed FSCA reference</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://www.semanticweb.org/joann/ontologies/2026/2/eudamed-ontology/eudamed_incident_ref -->


    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/joann/ontologies/2026/2/eudamed-ontology/eudamed_incident_ref">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/joann/ontologies/2026/2/eudamed-ontology/Incident"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment xml:lang="en">The unique reference number assigned to an incident report in the EUDAMED database.</rdfs:comment>
        <rdfs:label xml:lang="en">Eudamed incident reference</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://www.semanticweb.org/joann/ontologies/2026/2/eudamed-ontology/eudamed_srn -->


    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/joann/ontologies/2026/2/eudamed-ontology/eudamed_srn">
        <rdfs:domain rdf:resource="https://schema.org/Organization"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment xml:lang="en">The unique Single Registration Number (SRN) assigned to an economic operator in the EUDAMED system.</rdfs:comment>
        <rdfs:label xml:lang="en">Eudamed SRN</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://www.semanticweb.org/joann/ontologies/2026/2/eudamed-ontology/event_date -->


    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/joann/ontologies/2026/2/eudamed-ontology/event_date">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/joann/ontologies/2026/2/eudamed-ontology/Incident"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#date"/>
        <rdfs:comment xml:lang="en">The date on which the incident occurred.</rdfs:comment>
        <rdfs:label xml:lang="en">Event date</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://www.semanticweb.org/joann/ontologies/2026/2/eudamed-ontology/imdrf_code -->


    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/joann/ontologies/2026/2/eudamed-ontology/imdrf_code">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/joann/ontologies/2026/2/eudamed-ontology/MedicalRisk"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment xml:lang="en">The code from the International Medical Device Regulators Forum (IMDRF) that classifies the type of medical risk.</rdfs:comment>
        <rdfs:label xml:lang="en">IMDRF Code</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://www.semanticweb.org/joann/ontologies/2026/2/eudamed-ontology/incident_type -->


    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/joann/ontologies/2026/2/eudamed-ontology/incident_type">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/joann/ontologies/2026/2/eudamed-ontology/Incident"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment xml:lang="en">The classification of the incident, e.g., serious incident or near-miss.</rdfs:comment>
        <rdfs:label xml:lang="en">Incident type</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://www.semanticweb.org/joann/ontologies/2026/2/eudamed-ontology/intended_purpose -->


    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/joann/ontologies/2026/2/eudamed-ontology/intended_purpose">
        <rdfs:domain rdf:resource="https://schema.org/MedicalDevice"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment xml:lang="en">The intended use or clinical function of the medical device as defined by the manufacturer.</rdfs:comment>
        <rdfs:label xml:lang="en">Intended purpose</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://www.semanticweb.org/joann/ontologies/2026/2/eudamed-ontology/is_active -->


    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/joann/ontologies/2026/2/eudamed-ontology/is_active">
        <rdfs:domain rdf:resource="https://schema.org/MedicalDevice"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#boolean"/>
        <rdfs:comment xml:lang="en">A boolean flag indicating whether the device is an active medical device (dependent on a source of energy).</rdfs:comment>
        <rdfs:label xml:lang="en">Is active</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://www.semanticweb.org/joann/ontologies/2026/2/eudamed-ontology/is_implantable -->


    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/joann/ontologies/2026/2/eudamed-ontology/is_implantable">
        <rdfs:domain rdf:resource="https://schema.org/MedicalDevice"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#boolean"/>
        <rdfs:comment xml:lang="en">A boolean flag indicating whether the device is intended to be partially or wholly introduced into the human body.</rdfs:comment>
        <rdfs:label xml:lang="en">Is implantable</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://www.semanticweb.org/joann/ontologies/2026/2/eudamed-ontology/is_ivd -->


    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/joann/ontologies/2026/2/eudamed-ontology/is_ivd">
        <rdfs:domain rdf:resource="https://schema.org/MedicalDevice"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#boolean"/>
        <rdfs:comment xml:lang="en">A boolean flag indicating whether the device is an In-Vitro Diagnostic (IVD) medical device.</rdfs:comment>
        <rdfs:label xml:lang="en">Is IVD device</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://www.semanticweb.org/joann/ontologies/2026/2/eudamed-ontology/is_reusable -->


    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/joann/ontologies/2026/2/eudamed-ontology/is_reusable">
        <rdfs:domain rdf:resource="https://schema.org/MedicalDevice"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#boolean"/>
        <rdfs:comment xml:lang="en">A boolean flag indicating whether the device can be reused after appropriate processing.</rdfs:comment>
        <rdfs:label xml:lang="en">Is reusable</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://www.semanticweb.org/joann/ontologies/2026/2/eudamed-ontology/outcome -->


    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/joann/ontologies/2026/2/eudamed-ontology/outcome">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/joann/ontologies/2026/2/eudamed-ontology/Incident"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment xml:lang="en">A textual description of the consequences of the incident, such as patient harm or device malfunction.</rdfs:comment>
        <rdfs:label xml:lang="en">Outcome</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://www.semanticweb.org/joann/ontologies/2026/2/eudamed-ontology/patient_age -->


    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/joann/ontologies/2026/2/eudamed-ontology/patient_age">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/joann/ontologies/2026/2/eudamed-ontology/Incident"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment xml:lang="en">The age of the patient involved in the incident.</rdfs:comment>
        <rdfs:label xml:lang="en">Patient age</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://www.semanticweb.org/joann/ontologies/2026/2/eudamed-ontology/patient_sex -->


    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/joann/ontologies/2026/2/eudamed-ontology/patient_sex">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/joann/ontologies/2026/2/eudamed-ontology/Incident"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/joann/ontologies/2026/2/eudamed-ontology/personGender"/>
        <rdfs:comment xml:lang="en">The sex of the patient involved in the incident.</rdfs:comment>
        <rdfs:label xml:lang="en">Patient sex</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://www.semanticweb.org/joann/ontologies/2026/2/eudamed-ontology/probability -->


    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/joann/ontologies/2026/2/eudamed-ontology/probability">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/joann/ontologies/2026/2/eudamed-ontology/MedicalRisk"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment xml:lang="en">The estimated likelihood of the risk occurring (e.g., Low, Medium, High).</rdfs:comment>
        <rdfs:label xml:lang="en">Probability</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://www.semanticweb.org/joann/ontologies/2026/2/eudamed-ontology/regulatory_framework -->


    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/joann/ontologies/2026/2/eudamed-ontology/regulatory_framework">
        <rdfs:domain rdf:resource="https://schema.org/MedicalDevice"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment xml:lang="en">The applicable regulation under which the device is placed on the market, such as MDR or IVDR.</rdfs:comment>
        <rdfs:label xml:lang="en">Regulatory framework</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://www.semanticweb.org/joann/ontologies/2026/2/eudamed-ontology/risk_category -->


    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/joann/ontologies/2026/2/eudamed-ontology/risk_category">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/joann/ontologies/2026/2/eudamed-ontology/MedicalRisk"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment xml:lang="en">The category of risk, such as Device Failure, Patient Harm, or Diagnostic Error.</rdfs:comment>
        <rdfs:label xml:lang="en">Risk category</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://www.semanticweb.org/joann/ontologies/2026/2/eudamed-ontology/risk_class -->


    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/joann/ontologies/2026/2/eudamed-ontology/risk_class">
        <rdfs:domain rdf:resource="https://schema.org/MedicalDevice"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment xml:lang="en">The device risk class according to the regulatory framework (e.g., Class I, IIa, IIb, III for MDR; Class A, B, C, D for IVDR).</rdfs:comment>
        <rdfs:label xml:lang="en">Risk class</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://www.semanticweb.org/joann/ontologies/2026/2/eudamed-ontology/risk_type -->


    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/joann/ontologies/2026/2/eudamed-ontology/risk_type">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/joann/ontologies/2026/2/eudamed-ontology/MedicalRisk"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment xml:lang="en">A more specific classification of the risk, e.g., Malfunction Risk, Infection Risk, or Diagnostic Risk.</rdfs:comment>
        <rdfs:label xml:lang="en">Risk type</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://www.semanticweb.org/joann/ontologies/2026/2/eudamed-ontology/scope -->


    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/joann/ontologies/2026/2/eudamed-ontology/scope">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/joann/ontologies/2026/2/eudamed-ontology/CorrectiveAction"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment xml:lang="en">A textual description of the scope of a corrective action, detailing which devices or batches are included.</rdfs:comment>
        <rdfs:label xml:lang="en">Scope</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://www.semanticweb.org/joann/ontologies/2026/2/eudamed-ontology/severity -->


    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/joann/ontologies/2026/2/eudamed-ontology/severity">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/joann/ontologies/2026/2/eudamed-ontology/MedicalRisk"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment xml:lang="en">The level of severity of the medical risk (e.g., Critical, Serious, Moderate).</rdfs:comment>
        <rdfs:label xml:lang="en">Severity</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://www.semanticweb.org/joann/ontologies/2026/2/eudamed-ontology/status -->


    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/joann/ontologies/2026/2/eudamed-ontology/status">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/joann/ontologies/2026/2/eudamed-ontology/CorrectiveAction"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment xml:lang="en">The current status of a corrective action (e.g., Open, Closed).</rdfs:comment>
        <rdfs:label xml:lang="en">Status</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://www.semanticweb.org/joann/ontologies/2026/2/eudamed-ontology/udi_di -->


    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/joann/ontologies/2026/2/eudamed-ontology/udi_di">
        <rdfs:domain rdf:resource="https://schema.org/MedicalDevice"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment xml:lang="en">The Unique Device Identifier - Device Identifier (UDI-DI) which serves as the primary identifier for a medical device model.</rdfs:comment>
        <rdfs:label xml:lang="en">Unique Device Identifier - Device Identifier</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Classes
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->


    


    <!-- http://www.semanticweb.org/joann/ontologies/2026/2/eudamed-ontology/ActiveDevice -->


    <owl:Class rdf:about="http://www.semanticweb.org/joann/ontologies/2026/2/eudamed-ontology/ActiveDevice">
        <rdfs:subClassOf rdf:resource="https://schema.org/MedicalDevice"/>
        <rdfs:comment xml:lang="en">A device that depends on a source of energy (e.g., electrical, mechanical) to perform its function, excluding energy generated by the human body.</rdfs:comment>
        <rdfs:label xml:lang="en">Active medical device</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/joann/ontologies/2026/2/eudamed-ontology/ClassI -->


    <owl:Class rdf:about="http://www.semanticweb.org/joann/ontologies/2026/2/eudamed-ontology/ClassI">
        <rdfs:subClassOf rdf:resource="https://schema.org/MedicalDevice"/>
        <rdfs:comment xml:lang="en">A low‑risk medical device under MDR 2017/745, typically subject to self‑declaration of conformity.</rdfs:comment>
        <rdfs:label xml:lang="en">Class I medical device</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/joann/ontologies/2026/2/eudamed-ontology/ClassIII -->


    <owl:Class rdf:about="http://www.semanticweb.org/joann/ontologies/2026/2/eudamed-ontology/ClassIII">
        <rdfs:subClassOf rdf:resource="https://schema.org/MedicalDevice"/>
        <rdfs:comment xml:lang="en">A high‑risk medical device under MDR 2017/745, requiring the highest level of scrutiny and clinical evaluation.</rdfs:comment>
        <rdfs:label xml:lang="en">Class III medical device</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/joann/ontologies/2026/2/eudamed-ontology/ClassIIa -->


    <owl:Class rdf:about="http://www.semanticweb.org/joann/ontologies/2026/2/eudamed-ontology/ClassIIa">
        <rdfs:subClassOf rdf:resource="https://schema.org/MedicalDevice"/>
        <rdfs:comment xml:lang="en">A medium‑risk medical device under MDR 2017/745, with moderate conformity assessment requirements.</rdfs:comment>
        <rdfs:label xml:lang="en">Class IIa medical device</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/joann/ontologies/2026/2/eudamed-ontology/ClassIIb -->


    <owl:Class rdf:about="http://www.semanticweb.org/joann/ontologies/2026/2/eudamed-ontology/ClassIIb">
        <rdfs:subClassOf rdf:resource="https://schema.org/MedicalDevice"/>
        <rdfs:comment xml:lang="en">A medium‑high risk medical device under MDR 2017/745, subject to strict conformity assessment procedures.</rdfs:comment>
        <rdfs:label xml:lang="en">Class IIb medical device</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/joann/ontologies/2026/2/eudamed-ontology/ContaminationRisk -->


    <owl:Class rdf:about="http://www.semanticweb.org/joann/ontologies/2026/2/eudamed-ontology/ContaminationRisk">
        <owl:equivalentClass>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="http://www.semanticweb.org/joann/ontologies/2026/2/eudamed-ontology/MedicalRisk"/>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="http://www.semanticweb.org/joann/ontologies/2026/2/eudamed-ontology/risk_type"/>
                        <owl:hasValue>ContaminationRisk</owl:hasValue>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </owl:equivalentClass>
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/joann/ontologies/2026/2/eudamed-ontology/MedicalRisk"/>
        <rdfs:comment xml:lang="en">Risk of microbial or chemical contamination of the device, potentially causing infection or adverse health effects.</rdfs:comment>
        <rdfs:label xml:lang="en">Contamination risk</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/joann/ontologies/2026/2/eudamed-ontology/CorrectiveAction -->


    <owl:Class rdf:about="http://www.semanticweb.org/joann/ontologies/2026/2/eudamed-ontology/CorrectiveAction">
        <rdfs:comment xml:lang="en">A safety measure taken to address a device-related incident, including field safety corrective actions (FSCA) and recalls.</rdfs:comment>
        <rdfs:label xml:lang="en">Corrective action</rdfs:label>
        <owl:sameAs>http://dbpedia.org/resource/Corrective_and_preventive_action</owl:sameAs>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/joann/ontologies/2026/2/eudamed-ontology/CybersecurityRisk -->


    <owl:Class rdf:about="http://www.semanticweb.org/joann/ontologies/2026/2/eudamed-ontology/CybersecurityRisk">
        <owl:equivalentClass>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="http://www.semanticweb.org/joann/ontologies/2026/2/eudamed-ontology/MedicalRisk"/>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="http://www.semanticweb.org/joann/ontologies/2026/2/eudamed-ontology/risk_type"/>
                        <owl:hasValue>CybersecurityRisk</owl:hasValue>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </owl:equivalentClass>
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/joann/ontologies/2026/2/eudamed-ontology/MedicalRisk"/>
        <rdfs:comment xml:lang="en">Risk arising from vulnerabilities in the device&apos;s software or network connectivity that could lead to unauthorized access or malfunction.</rdfs:comment>
        <rdfs:label xml:lang="en">Cybersecurity risk</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/joann/ontologies/2026/2/eudamed-ontology/DiagnosticRisk -->


    <owl:Class rdf:about="http://www.semanticweb.org/joann/ontologies/2026/2/eudamed-ontology/DiagnosticRisk">
        <owl:equivalentClass>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="http://www.semanticweb.org/joann/ontologies/2026/2/eudamed-ontology/MedicalRisk"/>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="http://www.semanticweb.org/joann/ontologies/2026/2/eudamed-ontology/risk_type"/>
                        <owl:hasValue>DiagnosticRisk</owl:hasValue>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </owl:equivalentClass>
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/joann/ontologies/2026/2/eudamed-ontology/MedicalRisk"/>
        <rdfs:comment xml:lang="en">Risk associated with incorrect or delayed diagnosis due to device failure or misinterpretation of results.</rdfs:comment>
        <rdfs:label xml:lang="en">Diagnostic risk</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/joann/ontologies/2026/2/eudamed-ontology/ImplantableDevice -->


    <owl:Class rdf:about="http://www.semanticweb.org/joann/ontologies/2026/2/eudamed-ontology/ImplantableDevice">
        <rdfs:subClassOf rdf:resource="https://schema.org/MedicalDevice"/>
        <rdfs:comment xml:lang="en">A device intended to be placed into the human body, either partially or wholly, and remains after the procedure.</rdfs:comment>
        <rdfs:label xml:lang="en">Implantable medical device</rdfs:label>
        <owl:sameAs>https://dbpedia.org/page/Implant_(medicine)</owl:sameAs>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/joann/ontologies/2026/2/eudamed-ontology/InSituCorrection -->


    <owl:Class rdf:about="http://www.semanticweb.org/joann/ontologies/2026/2/eudamed-ontology/InSituCorrection">
        <owl:equivalentClass>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="http://www.semanticweb.org/joann/ontologies/2026/2/eudamed-ontology/CorrectiveAction"/>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="http://www.semanticweb.org/joann/ontologies/2026/2/eudamed-ontology/action_type"/>
                        <owl:hasValue>InSituCorrection</owl:hasValue>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </owl:equivalentClass>
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/joann/ontologies/2026/2/eudamed-ontology/CorrectiveAction"/>
        <rdfs:comment xml:lang="en">A corrective action performed directly on the device at the point of use, such as a software update or hardware adjustment.</rdfs:comment>
        <rdfs:label xml:lang="en">In-Situ correction</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/joann/ontologies/2026/2/eudamed-ontology/InVitroDiagnostic -->


    <owl:Class rdf:about="http://www.semanticweb.org/joann/ontologies/2026/2/eudamed-ontology/InVitroDiagnostic">
        <rdfs:subClassOf rdf:resource="https://schema.org/MedicalDevice"/>
        <rdfs:comment xml:lang="en">A device used to examine specimens derived from the human body to provide information for diagnostic or monitoring purposes (IVDR 2017/746).</rdfs:comment>
        <rdfs:label xml:lang="en">In-Vitro diagnostic medical device</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/joann/ontologies/2026/2/eudamed-ontology/Incident -->


    <owl:Class rdf:about="http://www.semanticweb.org/joann/ontologies/2026/2/eudamed-ontology/Incident">
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://www.semanticweb.org/joann/ontologies/2026/2/eudamed-ontology/hasRisk"/>
                <owl:minQualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:minQualifiedCardinality>
                <owl:onClass rdf:resource="http://www.semanticweb.org/joann/ontologies/2026/2/eudamed-ontology/MedicalRisk"/>
            </owl:Restriction>
        </rdfs:subClassOf>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/joann/ontologies/2026/2/eudamed-ontology/InfectionRisk -->


    <owl:Class rdf:about="http://www.semanticweb.org/joann/ontologies/2026/2/eudamed-ontology/InfectionRisk">
        <owl:equivalentClass>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="http://www.semanticweb.org/joann/ontologies/2026/2/eudamed-ontology/MedicalRisk"/>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="http://www.semanticweb.org/joann/ontologies/2026/2/eudamed-ontology/risk_type"/>
                        <owl:hasValue>InfectionRisk</owl:hasValue>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </owl:equivalentClass>
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/joann/ontologies/2026/2/eudamed-ontology/MedicalRisk"/>
        <rdfs:comment xml:lang="en">Risk that the device causes or contributes to infection, particularly in implantable or reusable devices.</rdfs:comment>
        <rdfs:label xml:lang="en">Infection risk</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/joann/ontologies/2026/2/eudamed-ontology/InjuryRisk -->


    <owl:Class rdf:about="http://www.semanticweb.org/joann/ontologies/2026/2/eudamed-ontology/InjuryRisk">
        <owl:equivalentClass>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="http://www.semanticweb.org/joann/ontologies/2026/2/eudamed-ontology/MedicalRisk"/>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="http://www.semanticweb.org/joann/ontologies/2026/2/eudamed-ontology/risk_type"/>
                        <owl:hasValue>InjuryRisk</owl:hasValue>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </owl:equivalentClass>
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/joann/ontologies/2026/2/eudamed-ontology/MedicalRisk"/>
        <rdfs:comment xml:lang="en">Risk of physical harm or injury to the patient or user due to device failure or misuse.</rdfs:comment>
        <rdfs:label xml:lang="en">Injury risk</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/joann/ontologies/2026/2/eudamed-ontology/InterferenceRisk -->


    <owl:Class rdf:about="http://www.semanticweb.org/joann/ontologies/2026/2/eudamed-ontology/InterferenceRisk">
        <owl:equivalentClass>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="http://www.semanticweb.org/joann/ontologies/2026/2/eudamed-ontology/MedicalRisk"/>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="http://www.semanticweb.org/joann/ontologies/2026/2/eudamed-ontology/risk_type"/>
                        <owl:hasValue>InterferenceRisk</owl:hasValue>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </owl:equivalentClass>
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/joann/ontologies/2026/2/eudamed-ontology/MedicalRisk"/>
        <rdfs:comment xml:lang="en">Risk that the device causes or is affected by electromagnetic or other interference, compromising its performance.</rdfs:comment>
        <rdfs:label xml:lang="en">Interference risk</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/joann/ontologies/2026/2/eudamed-ontology/MalfunctionRisk -->


    <owl:Class rdf:about="http://www.semanticweb.org/joann/ontologies/2026/2/eudamed-ontology/MalfunctionRisk">
        <owl:equivalentClass>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="http://www.semanticweb.org/joann/ontologies/2026/2/eudamed-ontology/MedicalRisk"/>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="http://www.semanticweb.org/joann/ontologies/2026/2/eudamed-ontology/risk_type"/>
                        <owl:hasValue>MalfunctionRisk</owl:hasValue>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </owl:equivalentClass>
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/joann/ontologies/2026/2/eudamed-ontology/MedicalRisk"/>
        <rdfs:comment xml:lang="en">Risk that the device fails to perform as intended, potentially leading to delayed treatment or harm.</rdfs:comment>
        <rdfs:label xml:lang="en">Malfunction risk</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/joann/ontologies/2026/2/eudamed-ontology/MaterialRisk -->


    <owl:Class rdf:about="http://www.semanticweb.org/joann/ontologies/2026/2/eudamed-ontology/MaterialRisk">
        <owl:equivalentClass>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="http://www.semanticweb.org/joann/ontologies/2026/2/eudamed-ontology/MedicalRisk"/>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="http://www.semanticweb.org/joann/ontologies/2026/2/eudamed-ontology/risk_type"/>
                        <owl:hasValue>MaterialRisk</owl:hasValue>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </owl:equivalentClass>
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/joann/ontologies/2026/2/eudamed-ontology/MedicalRisk"/>
        <rdfs:comment xml:lang="en">Risk related to the materials used in the device, such as toxicity or biocompatibility issues.</rdfs:comment>
        <rdfs:label xml:lang="en">Material risk</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/joann/ontologies/2026/2/eudamed-ontology/MedicalRisk -->


    <owl:Class rdf:about="http://www.semanticweb.org/joann/ontologies/2026/2/eudamed-ontology/MedicalRisk">
        <rdfs:comment xml:lang="en">A potential hazard associated with a medical device, classified according to the IMDRF nomenclature.</rdfs:comment>
        <rdfs:label xml:lang="en">Medical risk</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/joann/ontologies/2026/2/eudamed-ontology/NearMissIncident -->


    <owl:Class rdf:about="http://www.semanticweb.org/joann/ontologies/2026/2/eudamed-ontology/NearMissIncident">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/joann/ontologies/2026/2/eudamed-ontology/Incident"/>
        <rdfs:comment xml:lang="en">An event that could have led to harm but did not, often due to timely intervention or chance.</rdfs:comment>
        <rdfs:label xml:lang="en">Near-Miss incident</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/joann/ontologies/2026/2/eudamed-ontology/NonActiveDevice -->


    <owl:Class rdf:about="http://www.semanticweb.org/joann/ontologies/2026/2/eudamed-ontology/NonActiveDevice">
        <rdfs:subClassOf rdf:resource="https://schema.org/MedicalDevice"/>
        <rdfs:comment xml:lang="en">A device that does not rely on electrical or mechanical energy to function, such as bandages or surgical instruments.</rdfs:comment>
        <rdfs:label xml:lang="en">Non-Active medial device</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/joann/ontologies/2026/2/eudamed-ontology/RadiationRisk -->


    <owl:Class rdf:about="http://www.semanticweb.org/joann/ontologies/2026/2/eudamed-ontology/RadiationRisk">
        <owl:equivalentClass>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="http://www.semanticweb.org/joann/ontologies/2026/2/eudamed-ontology/MedicalRisk"/>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="http://www.semanticweb.org/joann/ontologies/2026/2/eudamed-ontology/risk_type"/>
                        <owl:hasValue>RadiationRisk</owl:hasValue>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </owl:equivalentClass>
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/joann/ontologies/2026/2/eudamed-ontology/MedicalRisk"/>
        <rdfs:comment xml:lang="en">Risk of excessive or unintended radiation exposure from the device, leading to tissue damage or other health effects.</rdfs:comment>
        <rdfs:label xml:lang="en">Radiation risk</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/joann/ontologies/2026/2/eudamed-ontology/Recall -->


    <owl:Class rdf:about="http://www.semanticweb.org/joann/ontologies/2026/2/eudamed-ontology/Recall">
        <owl:equivalentClass>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="http://www.semanticweb.org/joann/ontologies/2026/2/eudamed-ontology/CorrectiveAction"/>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="http://www.semanticweb.org/joann/ontologies/2026/2/eudamed-ontology/action_type"/>
                        <owl:hasValue>Recall</owl:hasValue>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </owl:equivalentClass>
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/joann/ontologies/2026/2/eudamed-ontology/CorrectiveAction"/>
        <rdfs:comment xml:lang="en">Removal or correction of a device that is in violation of regulations or poses a safety risk, conducted by the manufacturer.</rdfs:comment>
        <rdfs:label xml:lang="en">Recall</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/joann/ontologies/2026/2/eudamed-ontology/SafetyAlert -->


    <owl:Class rdf:about="http://www.semanticweb.org/joann/ontologies/2026/2/eudamed-ontology/SafetyAlert">
        <owl:equivalentClass>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="http://www.semanticweb.org/joann/ontologies/2026/2/eudamed-ontology/CorrectiveAction"/>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="http://www.semanticweb.org/joann/ontologies/2026/2/eudamed-ontology/action_type"/>
                        <owl:hasValue>SafetyAlert</owl:hasValue>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </owl:equivalentClass>
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/joann/ontologies/2026/2/eudamed-ontology/CorrectiveAction"/>
        <rdfs:comment xml:lang="en">An urgent notification issued to inform users about a serious safety issue and to recommend specific actions.</rdfs:comment>
        <rdfs:label xml:lang="en">Safety alert</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/joann/ontologies/2026/2/eudamed-ontology/SeriousIncident -->


    <owl:Class rdf:about="http://www.semanticweb.org/joann/ontologies/2026/2/eudamed-ontology/SeriousIncident">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/joann/ontologies/2026/2/eudamed-ontology/Incident"/>
        <rdfs:comment xml:lang="en">An incident that resulted in death, serious deterioration in health, or a life‑threatening situation.</rdfs:comment>
        <rdfs:label xml:lang="en">Serious incident</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/joann/ontologies/2026/2/eudamed-ontology/SoftwareRisk -->


    <owl:Class rdf:about="http://www.semanticweb.org/joann/ontologies/2026/2/eudamed-ontology/SoftwareRisk">
        <owl:equivalentClass>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="http://www.semanticweb.org/joann/ontologies/2026/2/eudamed-ontology/MedicalRisk"/>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="http://www.semanticweb.org/joann/ontologies/2026/2/eudamed-ontology/risk_type"/>
                        <owl:hasValue>SoftwareRisk</owl:hasValue>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </owl:equivalentClass>
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/joann/ontologies/2026/2/eudamed-ontology/MedicalRisk"/>
        <rdfs:comment xml:lang="en">Risk associated with software bugs, inadequate functionality, or cybersecurity flaws in the device&apos;s software.</rdfs:comment>
        <rdfs:label xml:lang="en">Software risk</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/joann/ontologies/2026/2/eudamed-ontology/UserNotice -->


    <owl:Class rdf:about="http://www.semanticweb.org/joann/ontologies/2026/2/eudamed-ontology/UserNotice">
        <owl:equivalentClass>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="http://www.semanticweb.org/joann/ontologies/2026/2/eudamed-ontology/CorrectiveAction"/>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="http://www.semanticweb.org/joann/ontologies/2026/2/eudamed-ontology/action_type"/>
                        <owl:hasValue>UserNotice</owl:hasValue>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </owl:equivalentClass>
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/joann/ontologies/2026/2/eudamed-ontology/CorrectiveAction"/>
        <rdfs:comment xml:lang="en">A communication to users (e.g., healthcare providers, patients) providing instructions or warnings regarding device use.</rdfs:comment>
        <rdfs:label xml:lang="en">User notice</rdfs:label>
    </owl:Class>
    


